def _parse_suggestions(text):
    """Parse numbered suggestions from skill output.

    Handles multiple formats:
      - **`fix 1`** — Title here
      - `fix 1` — Title here
      ## 1. Title\nDescription...
      **1. Title**\nDescription...
    """
    suggestions = []

    # Format 1: bullet list with `fix N` — used by improve/deslop/envision menu
    fix_pattern = r'[-*]\s*\*{0,2}`?fix\s+(\d+)`?\*{0,2}\s*[—\-–:]\s*(.+?)(?:\n|$)'
    fix_matches = list(re.finditer(fix_pattern, text, re.IGNORECASE))
    if fix_matches:
        for m in fix_matches:
            num = int(m.group(1))
            title = m.group(2).strip().rstrip("*").strip()
            suggestions.append({"index": num, "title": title, "body": ""})
        return suggestions

    # Format 2: "N. **bold title** — description" (common skill output)
    bold_pattern = r'(?:^|\n)\s*(\d+)\.\s*\*\*(.+?)\*\*\s*[—\-–]\s*(.+?)(?=\n\s*\d+\.\s*\*\*|\n\s*##|\Z)'
    bold_matches = list(re.finditer(bold_pattern, text, re.DOTALL))
    if bold_matches:
        for m in bold_matches:
            num = int(m.group(1))
            title = m.group(2).strip()
            body = m.group(3).strip()
            # Clean up body: remove scope lines, trim
            body = re.sub(r'\s*Scope:.*$', '', body, flags=re.MULTILINE).strip()
            suggestions.append({
                "index": num,
                "title": title,
                "body": body[:500],
            })
        return suggestions

    # Format 3: "## N. Title" or "### N: Title" headers
    hdr_pattern = r'(?:^|\n)#{1,3}\s*(\d+)[.\):\-]\s*(.+?)(?:\n|$)'
    hdr_matches = list(re.finditer(hdr_pattern, text))
    if hdr_matches:
        for i, match in enumerate(hdr_matches):
            num = match.group(1)
            title = match.group(2).strip().rstrip("*").strip()
            start = match.end()
            end = hdr_matches[i + 1].start() if i + 1 < len(hdr_matches) else len(text)
            body = text[start:end].strip()
            suggestions.append({
                "index": int(num),
                "title": title,
                "body": body[:500],
            })
        return suggestions

    return suggestions


