def format_tokens(n):
    """Format token count to human-readable."""
    if n >= 1_000_000:
        return f"{n / 1_000_000:.1f}M"
    if n >= 1_000:
        return f"{n / 1_000:.1f}K"
    return str(n)


def format_bytes(b):
    for unit in ["B", "K", "M", "G", "T"]:
        if abs(b) < 1024.0:
            return f"{b:5.1f}{unit}"
        b /= 1024.0
    return f"{b:.1f}P"


def format_time(secs):
    h = int(secs // 3600)
    m = int((secs % 3600) // 60)
    s = int(secs % 60)
    if h > 0:
        return f"{h:d}:{m:02d}:{s:02d}"
    return f"{m:d}:{s:02d}"


def format_duration_human(secs):
    """Format like Claude Code: '2m 3s', '45s', '1h 2m'."""
    h = int(secs // 3600)
    m = int((secs % 3600) // 60)
    s = int(secs % 60)
    if h > 0:
        return f"{h}h {m}m"
    if m > 0:
        return f"{m}m {s}s"
    return f"{s}s"


def truncate(s, width):
    if len(s) <= width:
        return s
    return s[: width - 1] + "…"


def draw_bar(stdscr, y, x, width, pct, color_filled, color_empty=None):
    """Draw a percentage bar with optional two-tone coloring."""
    filled = int(width * min(pct, 100) / 100)
    filled = max(0, min(filled, width))
    try:
        if filled > 0:
            stdscr.addstr(y, x, "█" * filled, color_filled)
        remaining = width - filled
        if remaining > 0:
            empty_color = color_empty if color_empty else curses.color_pair(5)
            stdscr.addstr(y, x + filled, "░" * remaining, empty_color)
    except curses.error:
        pass


def safe_addstr(stdscr, y, x, text, attr=0):
    try:
        stdscr.addstr(y, x, text, attr)
    except curses.error:
        pass


_proc_cache = {}  # PID → psutil.Process; kept across refreshes for cpu_percent()
_proc_cache_lock = threading.Lock()
_subagent_cache = {}  # (subagent_dir, agent_id) → (mtime, parsed_data)
_subagent_cache_lock = threading.Lock()
_dir_listing_cache = {}  # dirpath → (mtime, [entries])
_dir_listing_cache_lock = threading.Lock()


def _cached_listdir(dirpath):
    """Return os.listdir(dirpath), cached by directory mtime to reduce I/O."""
    try:
        dir_mtime = os.path.getmtime(dirpath)
    except OSError:
        return []
    with _dir_listing_cache_lock:
        cached = _dir_listing_cache.get(dirpath)
        if cached and cached[0] == dir_mtime:
            return cached[1]
    try:
        entries = os.listdir(dirpath)
    except OSError:
        entries = []
    with _dir_listing_cache_lock:
        _dir_listing_cache[dirpath] = (dir_mtime, entries)
    return entries


def _parse_jsonl_tail(jsonl_path, read_size=512 * 1024):
    """Parse the tail of a JSONL file to extract activity, tokens, and state.

    Shared by both session and subagent parsing.
    Returns a dict with activity, model, tokens, turn timing, etc.
    """
    result = {
        "model": "?",
        "input_tokens": 0,
        "output_tokens": 0,
        "cache_read": 0,
        "cache_write": 0,
        "total_context": 0,
        "context_max": DEFAULT_CONTEXT,
        "context_pct": 0,
        "permission_mode": "?",
        "msg_count": 0,
        "tool_calls": 0,
        "activity": "Idle",
        "slug": "",
        "turn_start_ts": None,
        "last_turn_duration": None,
        "jsonl_mtime": 0,
        "last_assistant_age": None,
    }

    try:
        file_size = os.path.getsize(jsonl_path)
        jsonl_mtime = os.path.getmtime(jsonl_path)
        read_size = min(file_size, read_size)

        msg_count = 0
        tool_calls = 0
        last_model = None
        last_usage = None
        last_slug = ""
        total_input = 0
        total_output = 0
        total_cache_read = 0
        total_cache_write = 0
        last_type = ""
        last_content_types = []
        last_tool_name = ""
        last_assistant_stop = None
        last_assistant_ctypes = []
        last_assistant_tool = ""
        last_assistant_ts = None
        entry_seq = 0
        last_assistant_seq = 0
        last_user_seq = 0
        last_user_ctypes = []
        last_progress_type = ""
        turn_ended = False
        turn_start_ts = None
        last_turn_duration = None
        permission_mode = "?"

        with open(jsonl_path, "rb") as f:
            f.seek(max(0, file_size - read_size))
            if file_size > read_size:
                f.readline()  # skip partial line

            for line in f:
                try:
                    entry = json.loads(line)
                except (json.JSONDecodeError, UnicodeDecodeError):
                    continue

                if entry.get("permissionMode"):
                    permission_mode = entry["permissionMode"]

                if entry.get("slug"):
                    last_slug = entry["slug"]

                entry_type = entry.get("type", "")

                if entry_type == "system" and entry.get("subtype") == "turn_duration":
                    turn_ended = True
                    dur_ms = entry.get("durationMs") or entry.get("duration_ms")
                    if dur_ms:
                        try:
                            last_turn_duration = float(dur_ms) / 1000
                        except (ValueError, TypeError):
                            pass

                if entry_type == "progress":
                    progress_data_type = entry.get("data", {}).get("type", "")
                    if progress_data_type == "agent_progress":
                        last_progress_type = "agent_progress"
                elif entry_type in ("assistant", "user"):
                    last_progress_type = ""
                    turn_ended = False
                    if entry_type == "user":
                        ts = entry.get("timestamp")
                        if ts:
                            turn_start_ts = ts

                msg = entry.get("message", {})
                if not isinstance(msg, dict):
                    continue

                usage = msg.get("usage", {})
                model = msg.get("model", "")

                if model:
                    last_model = model

                if usage:
                    last_usage = usage
                    inp = usage.get("input_tokens", 0)
                    out = usage.get("output_tokens", 0)
                    cr = usage.get("cache_read_input_tokens", 0)
                    cw = usage.get("cache_creation_input_tokens", 0)
                    total_input += inp
                    total_output += out
                    total_cache_read += cr
                    total_cache_write += cw

                content = msg.get("content", [])
                if isinstance(content, list):
                    for item in content:
                        if isinstance(item, dict) and item.get("type") == "tool_use":
                            tool_calls += 1

                msg_count += 1

                if entry_type in ("assistant", "user"):
                    entry_seq += 1
                    last_type = entry_type
                    last_content_types = []
                    last_tool_name = ""
                    if isinstance(content, list):
                        for item in content:
                            if isinstance(item, dict):
                                last_content_types.append(item.get("type", ""))
                                if item.get("type") == "tool_use":
                                    last_tool_name = item.get("name", "")
                                elif item.get("type") == "tool_result":
                                    last_tool_name = ""

                    if entry_type == "assistant":
                        stop = msg.get("stop_reason")
                        last_assistant_ctypes = list(last_content_types)
                        last_assistant_tool = last_tool_name
                        last_assistant_stop = stop
                        last_assistant_seq = entry_seq
                        last_assistant_ts = entry.get("timestamp")

                    if entry_type == "user":
                        last_user_ctypes = list(last_content_types)
                        last_user_seq = entry_seq

        # Estimate messages in the skipped portion
        if file_size > read_size and msg_count > 0:
            tail_start = max(0, file_size - read_size)
            bytes_read = file_size - tail_start
            if bytes_read > 0:
                avg_line_size = bytes_read / msg_count
                skipped_estimate = int(tail_start / avg_line_size)
                msg_count += skipped_estimate

        # Context estimation
        if last_usage:
            ctx_tokens = (
                last_usage.get("cache_read_input_tokens", 0)
                + last_usage.get("cache_creation_input_tokens", 0)
                + last_usage.get("input_tokens", 0)
                + last_usage.get("output_tokens", 0)
            )
        else:
            ctx_tokens = 0

        ctx_max = MODEL_CONTEXT.get(last_model, DEFAULT_CONTEXT) if last_model else DEFAULT_CONTEXT
        ctx_pct = (ctx_tokens / ctx_max * 100) if ctx_max else 0

        # Activity derivation
        activity = "Idle"
        if turn_ended:
            activity = "Waiting"
        elif last_progress_type == "agent_progress":
            activity = "Running Agent"
        elif last_type == "assistant":
            if last_assistant_stop is not None:
                if last_assistant_stop == "end_turn":
                    activity = "Waiting"
                elif last_assistant_stop == "tool_use":
                    tool_label = last_assistant_tool or "tool"
                    if last_user_seq > last_assistant_seq and "tool_result" in last_user_ctypes:
                        activity = "Thinking"
                    else:
                        activity = f"Running {tool_label}"
                else:
                    activity = "Waiting"
            else:
                if "thinking" in last_assistant_ctypes:
                    activity = "Thinking"
                elif any(ct.startswith("tool_use") for ct in last_assistant_ctypes):
                    tool_label = last_assistant_tool or "tool"
                    activity = f"Using {tool_label}"
                elif "text" in last_assistant_ctypes:
                    activity = "Responding"
                else:
                    activity = "Thinking"
        elif last_type == "user":
            activity = "Thinking"

        # Assistant age for stale detection
        assistant_age = None
        if last_assistant_ts and last_assistant_stop is None:
            try:
                ts = datetime.fromisoformat(last_assistant_ts.replace("Z", "+00:00"))
                assistant_age = (datetime.now(timezone.utc) - ts).total_seconds()
            except (ValueError, TypeError):
                pass

        result.update({
            "activity": activity,
            "permission_mode": permission_mode,
            "model": last_model or "?",
            "input_tokens": total_input,
            "output_tokens": total_output,
            "cache_read": total_cache_read,
            "cache_write": total_cache_write,
            "total_context": ctx_tokens,
            "context_max": ctx_max,
            "context_pct": min(ctx_pct, 100),
            "msg_count": msg_count,
            "tool_calls": tool_calls,
            "slug": last_slug,
            "turn_start_ts": turn_start_ts,
            "last_turn_duration": last_turn_duration,
            "jsonl_mtime": jsonl_mtime,
            "last_assistant_age": assistant_age,
        })
    except OSError:
        pass

    return result


def _get_subagents(subagent_dir):
    """Parse all subagents in a directory, using cache for unchanged files."""
    subagents = []
    if not os.path.isdir(subagent_dir):
        return subagents

    for meta_file in glob.glob(os.path.join(subagent_dir, "*.meta.json")):
        try:
            with open(meta_file) as mf:
                meta = json.load(mf)
        except (OSError, json.JSONDecodeError):
            continue

        agent_type = meta.get("agentType", "?")
        agent_desc = meta.get("description", "")

        # Derive agent ID from meta filename: agent-XXXX.meta.json -> agent-XXXX
        base = os.path.basename(meta_file).replace(".meta.json", "")
        agent_id = base  # e.g. "agent-a567a531a9219a6c2"

        # Find the best JSONL for this agent
        primary_jsonl = os.path.join(subagent_dir, f"{agent_id}.jsonl")
        best_path = None
        best_mtime = 0

        if os.path.exists(primary_jsonl):
            try:
                best_mtime = os.path.getmtime(primary_jsonl)
                best_path = primary_jsonl
            except OSError:
                pass

        # Check compact files for this agent
        for f in _cached_listdir(subagent_dir):
            if f.startswith("agent-acompact-") and f.endswith(".jsonl"):
                fpath = os.path.join(subagent_dir, f)
                try:
                    mt = os.path.getmtime(fpath)
                    if mt > best_mtime:
                        best_mtime = mt
                        best_path = fpath
                except OSError:
                    pass

        if not best_path:
            # No JSONL — just return meta info with defaults
            subagents.append({
                "agent_id": agent_id,
                "type": agent_type,
                "desc": agent_desc,
                "activity": "Idle",
                "total_context": 0,
                "context_max": DEFAULT_CONTEXT,
                "context_pct": 0,
                "model": "?",
                "output_tokens": 0,
                "turn_start_ts": None,
                "last_turn_duration": None,
            })
            continue

        # Check cache
        cache_key = (subagent_dir, agent_id)
        with _subagent_cache_lock:
            cached = _subagent_cache.get(cache_key)
        if cached and cached[0] == best_mtime:
            data = cached[1]
        else:
            data = _parse_jsonl_tail(best_path, read_size=128 * 1024)
            with _subagent_cache_lock:
                _subagent_cache[cache_key] = (best_mtime, data)

        subagents.append({
            "agent_id": agent_id,
            "_subagent_dir": subagent_dir,
            "type": agent_type,
            "desc": agent_desc,
            "activity": data["activity"],
            "total_context": data["total_context"],
            "context_max": data["context_max"],
            "context_pct": data["context_pct"],
            "model": data["model"],
            "output_tokens": data["output_tokens"],
            "turn_start_ts": data["turn_start_ts"],
            "last_turn_duration": data["last_turn_duration"],
        })

    return subagents


_worktree_parent_cache = {}  # cwd → parent_cwd or None


def _resolve_worktree_parent(cwd):
    """For git worktrees, follow .git file back to the parent repo path."""
    if cwd in _worktree_parent_cache:
        return _worktree_parent_cache[cwd]

    result = None
    git_file = os.path.join(cwd, ".git")
    try:
        if os.path.isfile(git_file):
            with open(git_file) as f:
                content = f.read().strip()
            # Format: "gitdir: /path/to/repo/.git/worktrees/name"
            if content.startswith("gitdir:"):
                gitdir = content.split(":", 1)[1].strip()
                # Strip /worktrees/<name> to get /path/to/repo/.git
                if "/worktrees/" in gitdir:
                    main_git = gitdir.split("/worktrees/")[0]
                    # Strip /.git to get repo path
                    if main_git.endswith("/.git"):
                        result = main_git[:-5]
    except OSError:
        pass

    _worktree_parent_cache[cwd] = result
    return result


def get_active_sessions():
    """Get all active Claude Code sessions with their metadata."""
    sessions = []
    session_files = glob.glob(str(CLAUDE_DIR / "sessions" / "*.json"))
    seen_pids = set()

    for sf in session_files:
        try:
            pid = int(Path(sf).stem)
            if not psutil.pid_exists(pid):
                continue
            seen_pids.add(pid)

            with open(sf) as f:
                data = json.load(f)

            session_id = data.get("sessionId", "")
            cwd = data.get("cwd", "")
            started_at = data.get("startedAt", 0)
            elapsed = (time.time() * 1000 - started_at) / 1000 if started_at else 0

            try:
                with _proc_cache_lock:
                    if pid not in _proc_cache:
                        _proc_cache[pid] = psutil.Process(pid)
                    proc = _proc_cache[pid]
                cpu = proc.cpu_percent(interval=0)
                mem = proc.memory_info().rss
                children = proc.children(recursive=True)
                n_children = len(children)
                total_mem = mem + sum(c.memory_info().rss for c in children if c.is_running())
                child_types = {}
                for c in children:
                    try:
                        cname = c.name().lower()
                        if "bash" in cname:
                            key = "bash"
                        elif "zsh" in cname:
                            key = "zsh"
                        elif "sh" == cname:
                            key = "sh"
                        elif "python" in cname:
                            key = "python"
                        elif "node" in cname:
                            key = "node"
                        elif "deno" in cname:
                            key = "deno"
                        elif "bun" in cname:
                            key = "bun"
                        elif "cargo" in cname or "rustc" in cname:
                            key = "cargo"
                        elif "go" == cname:
                            key = "go"
                        elif "git" in cname:
                            key = "git"
                        elif "npm" in cname:
                            key = "npm"
                        elif "docker" in cname:
                            key = "docker"
                        elif "mcp" in cname:
                            key = "mcp"
                        else:
                            key = cname.split("/")[-1][:10]
                        child_types[key] = child_types.get(key, 0) + 1
                    except (psutil.NoSuchProcess, psutil.AccessDenied):
                        pass
            except (psutil.NoSuchProcess, psutil.AccessDenied):
                with _proc_cache_lock:
                    _proc_cache.pop(pid, None)
                cpu = 0
                mem = 0
                n_children = 0
                total_mem = 0
                child_types = {}

            ctx_info = get_session_context(session_id, cwd)

            if ctx_info["activity"] in ("Waiting", "Idle") and cpu > 5.0:
                ctx_info["activity"] = "Active"

            is_worker = cwd.startswith("/tmp/") or cwd.startswith("/private/tmp/")
            parent_cwd = _resolve_worktree_parent(cwd) if is_worker else None
            parent_project = os.path.basename(parent_cwd) if parent_cwd else None

            sessions.append({
                "pid": pid,
                "session_id": session_id,
                "cwd": cwd,
                "project": os.path.basename(cwd) if cwd else "?",
                "elapsed": elapsed,
                "cpu": cpu,
                "mem": total_mem,
                "children": n_children,
                "child_types": child_types,
                "is_worker": is_worker,
                "parent_cwd": parent_cwd,
                "parent_project": parent_project,
                **ctx_info,
            })
        except (json.JSONDecodeError, ValueError, OSError):
            continue

    with _proc_cache_lock:
        for stale_pid in set(_proc_cache) - seen_pids:
            del _proc_cache[stale_pid]

    return sessions


def get_session_context(session_id, cwd):
    """Extract context window usage from a session's JSONL file."""
    result = {
        "model": "?",
        "input_tokens": 0,
        "output_tokens": 0,
        "cache_read": 0,
        "cache_write": 0,
        "total_context": 0,
        "context_max": DEFAULT_CONTEXT,
        "context_pct": 0,
        "permission_mode": "?",
        "subagents": [],
        "msg_count": 0,
        "tool_calls": 0,
        "activity": "Idle",
        "slug": "",
        "turn_start_ts": None,
        "last_turn_duration": None,
    }

    if not session_id:
        return result

    # Find the JSONL file
    jsonl_path = None
    project_dir = None

    if cwd:
        project_dir_name = cwd.replace("/", "-").replace("_", "-")
        candidate_dir = str(CLAUDE_DIR / "projects" / project_dir_name)
        if os.path.isdir(candidate_dir):
            project_dir = candidate_dir
            exact = os.path.join(candidate_dir, f"{session_id}.jsonl")
            exact_exists = os.path.exists(exact)
            best_mtime = 0
            newest_path = None
            for f in _cached_listdir(candidate_dir):
                if f.endswith(".jsonl"):
                    fpath = os.path.join(candidate_dir, f)
                    try:
                        mt = os.path.getmtime(fpath)
                        if mt > best_mtime:
                            best_mtime = mt
                            newest_path = fpath
                    except OSError:
                        pass
            if exact_exists:
                try:
                    exact_mt = os.path.getmtime(exact)
                except OSError:
                    exact_mt = 0
                if newest_path and best_mtime - exact_mt > 30:
                    jsonl_path = newest_path
                else:
                    jsonl_path = exact
            elif newest_path:
                jsonl_path = newest_path

    if not jsonl_path:
        for pd in glob.glob(str(CLAUDE_DIR / "projects" / "*")):
            candidate = os.path.join(pd, f"{session_id}.jsonl")
            if os.path.exists(candidate):
                jsonl_path = candidate
                project_dir = pd
                break

    if not jsonl_path:
        return result

    # Parse the JSONL
    parsed = _parse_jsonl_tail(jsonl_path)

    # Find subagents
    jsonl_dir = os.path.dirname(jsonl_path)
    jsonl_session_id = os.path.basename(jsonl_path).replace(".jsonl", "")
    subagent_dir = os.path.join(jsonl_dir, jsonl_session_id, "subagents")
    subagents = _get_subagents(subagent_dir)

    result.update(parsed)
    result["subagents"] = subagents
    return result


def get_stats_cache():
    """Read the stats cache for historical usage data."""
    path = CLAUDE_DIR / "stats-cache.json"
    try:
        with open(path) as f:
            return json.load(f)
    except (OSError, json.JSONDecodeError):
        return {}


def find_claude_processes():
    """Find all processes related to Claude."""
    procs = []
    for proc in psutil.process_iter(
        ["pid", "ppid", "name", "cmdline", "cpu_percent", "memory_info",
         "memory_percent", "create_time", "status", "username", "num_threads"]
    ):
        try:
            info = proc.info
            name = (info["name"] or "").lower()
            cmdline = " ".join(info["cmdline"] or []).lower()

            is_claude = any(kw in name or kw in cmdline for kw in CLAUDE_KEYWORDS)
            if not is_claude:
                continue

            mem_info = info["memory_info"]
            create_time = info["create_time"]
            elapsed = time.time() - create_time if create_time else 0

            procs.append({
                "pid": info["pid"],
                "ppid": info["ppid"],
                "name": info["name"] or "?",
                "cmdline": " ".join(info["cmdline"] or []),
                "cpu": info["cpu_percent"] or 0.0,
                "mem_pct": info["memory_percent"] or 0.0,
                "mem_rss": mem_info.rss if mem_info else 0,
                "elapsed": elapsed,
                "status": info["status"] or "?",
                "user": info["username"] or "?",
                "threads": info["num_threads"] or 0,
            })
        except (psutil.NoSuchProcess, psutil.AccessDenied, psutil.ZombieProcess):
            continue
    return procs


def classify_process(cmdline):
    cl = cmdline.lower()
    if "claude-code" in cl or "claude code" in cl:
        return "Code"
    if "mcp" in cl:
        return "MCP"
    if "node" in cl and "claude" in cl:
        return "Node"
    if "claude" in cl:
        return "Claude"
    return "Other"


def shorten_model(model):
    """Shorten model name for display."""
    if not model or model == "?":
        return "?"
    m = model.lower()
    if "opus-4-6" in m:
        return "opus-4.6"
    if "opus-4-5" in m:
        return "opus-4.5"
    if "sonnet-4-6" in m:
        return "sonnet-4.6"
    if "sonnet-4-5" in m:
