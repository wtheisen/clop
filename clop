    col_agents = col_after_bar
    col_after_agents = col_agents + agents_w + 1
    col_phase = col_after_agents

    show_agents = col_agents + agents_w < w
    show_phase = col_phase + phase_w < w
    col_after_phase = (col_phase + phase_w + 1) if show_phase else col_after_agents
    show_model = col_after_phase + model_w < w

