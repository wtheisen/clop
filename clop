        safe_addstr(stdscr, row, 0, " " * w, SEL_HDR)
        safe_addstr(stdscr, row, 0, title, SEL_HDR)
        safe_addstr(stdscr, row, max(0, w - len(stats_right)), stats_right, SEL_HDR)
        row += 1

        # Jump flash feedback
        if jump_flash > 0:
            jump_flash -= 1
            flash_msg = " → jumped to tmux tab "
            safe_addstr(stdscr, row, max(0, (w - len(flash_msg)) // 2), flash_msg, GREEN)
            row += 1

        spin_frame += 1

        C = {
            "brand": BRAND, "beige": BEIGE, "amber": AMBER, "red": RED,
            "green": GREEN, "slate": SLATE, "sel": SEL_HDR, "dim": DIM,
            "peach": PEACH, "cream": CREAM,
            "teal": TEAL, "purple": PURPLE,
        }

        if view_mode == VIEW_SESSIONS:
            row = draw_sessions_view(stdscr, row, h, w, sessions,
                                     sort_idx_sessions, cursor_idx, selected_pid,
                                     collapsed_pids, spin_frame, C)
            # Rebuild display rows for cursor navigation
            cached_display_rows = build_display_rows(sessions, collapsed_pids)
            # Clamp cursor
            if cached_display_rows:
                max_idx = len(cached_display_rows) - 1
                cursor_idx = min(cursor_idx, max_idx)
                # Skip separator if cursor landed on one
                while cursor_idx > 0 and cached_display_rows[cursor_idx][0] == "separator":
                    cursor_idx -= 1
            else:
                cursor_idx = 0
        elif view_mode == VIEW_PROCESSES:
            cursor_idx = min(cursor_idx, max(0, len(procs) - 1))
            row = draw_processes_view(stdscr, row, h, w, procs,
                                      sort_idx_procs, cursor_idx, C)
        elif view_mode == VIEW_HISTORY:
            daily = stats_cache.get("dailyActivity", [])
            cursor_idx = min(cursor_idx, max(0, len(daily[-14:]) - 1))
            row = draw_history_view(stdscr, row, h, w, stats_cache,
                                    cursor_idx, C)

        # ── Footer ──
        footer = " q:Quit  Tab/v:View  s:Sort  g:Jump  Enter:Expand  p:Pause  ↑↓:Nav "
        safe_addstr(stdscr, h - 1, 0, " " * w, SEL_HDR)
        safe_addstr(stdscr, h - 1, 1, truncate(footer, w - 2), SEL_HDR)

        stdscr.refresh()


