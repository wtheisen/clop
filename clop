        curses.init_pair(10, C_DARK, C_CRIMSON)
        curses.init_pair(11, C_DARK, C_TERRACOTTA)
        curses.init_pair(12, C_DARK, C_BEIGE)
        curses.init_pair(13, C_PEACH, -1)
        curses.init_pair(14, C_CREAM, -1)
        curses.init_pair(15, C_TEAL, -1)
        curses.init_pair(16, C_PURPLE, -1)
    else:
        curses.init_pair(1, curses.COLOR_GREEN, -1)
        curses.init_pair(2, curses.COLOR_CYAN, -1)
        curses.init_pair(3, curses.COLOR_YELLOW, -1)
        curses.init_pair(4, curses.COLOR_RED, -1)
        curses.init_pair(5, curses.COLOR_WHITE, -1)
        curses.init_pair(6, curses.COLOR_YELLOW, -1)
        curses.init_pair(7, curses.COLOR_WHITE, curses.COLOR_RED)
        curses.init_pair(8, curses.COLOR_BLACK, curses.COLOR_GREEN)
        curses.init_pair(9, curses.COLOR_BLACK, curses.COLOR_YELLOW)
        curses.init_pair(10, curses.COLOR_BLACK, curses.COLOR_RED)
        curses.init_pair(11, curses.COLOR_BLACK, curses.COLOR_YELLOW)
        curses.init_pair(12, curses.COLOR_BLACK, curses.COLOR_CYAN)
        curses.init_pair(13, curses.COLOR_YELLOW, -1)
        curses.init_pair(14, curses.COLOR_WHITE, -1)
        curses.init_pair(15, curses.COLOR_CYAN, -1)
        curses.init_pair(16, curses.COLOR_MAGENTA, -1)

    GREEN = curses.color_pair(1) | curses.A_BOLD
    BEIGE = curses.color_pair(2)
    AMBER = curses.color_pair(3)
    RED = curses.color_pair(4) | curses.A_BOLD
    SLATE = curses.color_pair(5)
    BRAND = curses.color_pair(6) | curses.A_BOLD
    SEL_HDR = curses.color_pair(7) | curses.A_BOLD
    DIM = curses.color_pair(5) | curses.A_DIM
    BAR_GREEN = curses.color_pair(8)
    BAR_AMBER = curses.color_pair(9)
    BAR_RED = curses.color_pair(10)
    BAR_BRAND = curses.color_pair(11)
    BAR_MUTED = curses.color_pair(12)
    PEACH = curses.color_pair(13)
    CREAM = curses.color_pair(14)
    TEAL = curses.color_pair(15)
    PURPLE = curses.color_pair(16) | curses.A_BOLD

    view_mode = VIEW_SESSIONS
    sort_idx_sessions = 0
    sort_idx_procs = 0
    cursor_idx = 0
    selected_pid = -1  # PID of expanded session detail, -1 = none
    collapsed_pids = set()  # PIDs whose agent trees are collapsed
    manually_toggled = set()  # PIDs the user explicitly toggled
    paused = False

    # Prime CPU
    find_claude_processes()
    stats_cache = get_stats_cache()
    last_stats_refresh = time.time()
    last_data_refresh = 0
    cached_sessions = []
    cached_procs = []
    cached_display_rows = []
    spin_frame = 0
    DATA_REFRESH_INTERVAL = 2.0
    jump_flash = 0  # countdown frames for tmux jump feedback

    while True:
        key = stdscr.getch()
        if key == ord("q") or key == ord("Q"):
            break
        elif key == ord("\t") or key == ord("v") or key == ord("V"):
            view_mode = (view_mode + 1) % 3
            cursor_idx = 0
            selected_pid = -1
        elif key == ord("1"):
            view_mode = VIEW_SESSIONS
            cursor_idx = 0
        elif key == ord("2"):
            view_mode = VIEW_PROCESSES
            cursor_idx = 0
        elif key == ord("3"):
            view_mode = VIEW_HISTORY
            cursor_idx = 0
        elif key == ord("s") or key == ord("S"):
            if view_mode == VIEW_SESSIONS:
                sort_idx_sessions = (sort_idx_sessions + 1) % len(SORT_MODES_SESSIONS)
            elif view_mode == VIEW_PROCESSES:
                sort_idx_procs = (sort_idx_procs + 1) % len(SORT_MODES_PROCS)
        elif key == ord("p") or key == ord("P"):
            paused = not paused
        elif key == ord("g") or key == ord("G"):
            if view_mode == VIEW_SESSIONS and cached_display_rows:
                sess = get_cursor_session(cached_display_rows, cursor_idx)
                if sess:
                    if jump_to_tmux(sess["pid"]):
                        jump_flash = 15  # show feedback for ~1.2s
        elif key == curses.KEY_UP:
            if view_mode == VIEW_SESSIONS and cached_display_rows:
                # Skip separator rows
                new_idx = cursor_idx - 1
                while new_idx >= 0 and cached_display_rows[new_idx][0] == "separator":
                    new_idx -= 1
                cursor_idx = max(0, new_idx)
            else:
                cursor_idx = max(0, cursor_idx - 1)
        elif key == curses.KEY_DOWN:
            if view_mode == VIEW_SESSIONS and cached_display_rows:
                new_idx = cursor_idx + 1
                while new_idx < len(cached_display_rows) and cached_display_rows[new_idx][0] == "separator":
                    new_idx += 1
                if new_idx < len(cached_display_rows):
                    cursor_idx = new_idx
            elif view_mode == VIEW_PROCESSES:
                cursor_idx = min(cursor_idx + 1, max(0, len(cached_procs) - 1))
            else:
                max_items = len(stats_cache.get("dailyActivity", []))
                cursor_idx = min(cursor_idx + 1, max(0, max_items - 1))
        elif key == curses.KEY_HOME:
            cursor_idx = 0
        elif key == ord("\n") or key == ord(" "):
            if view_mode == VIEW_SESSIONS and cached_display_rows:
                if cursor_idx < len(cached_display_rows):
                    row_data = cached_display_rows[cursor_idx]
                    if row_data[0] == "session":
                        sess = row_data[1]
                        pid = sess["pid"]
                        # Toggle collapse/expand of subagent tree
                        if pid in collapsed_pids:
                            collapsed_pids.discard(pid)
                        else:
                            collapsed_pids.add(pid)
                        manually_toggled.add(pid)
                        # Rebuild display rows immediately
                        cached_display_rows = build_display_rows(cached_sessions, collapsed_pids)
                    elif row_data[0] == "agent":
                        # Toggle detail view for parent session
                        parent = row_data[2]
                        pid = parent["pid"]
                        if selected_pid == pid:
                            selected_pid = -1
                        else:
                            selected_pid = pid

        if paused:
            try:
                h, w = stdscr.getmaxyx()
                msg = " PAUSED (press p to resume) "
                stdscr.addstr(0, max(0, w - len(msg) - 1), msg, RED)
            except curses.error:
                pass
            stdscr.refresh()
            continue

        stdscr.erase()
        h, w = stdscr.getmaxyx()

        if h < 10 or w < 60:
            safe_addstr(stdscr, 0, 0, "Terminal too small (need 60x10+)", RED)
            stdscr.refresh()
            continue

        if time.time() - last_stats_refresh > 30:
            stats_cache = get_stats_cache()
            last_stats_refresh = time.time()

        now = datetime.now().strftime("%H:%M:%S")

        if time.time() - last_data_refresh >= DATA_REFRESH_INTERVAL:
            cached_sessions = get_active_sessions()
            cached_procs = find_claude_processes()
            last_data_refresh = time.time()

            # Auto-expand sessions with active agents (unless user manually collapsed)
            for s in cached_sessions:
                pid = s["pid"]
                if pid not in manually_toggled:
                    n_active = sum(1 for a in s.get("subagents", [])
                                   if a.get("activity") not in ACTIVITY_IDLE)
                    if n_active > 0:
                        collapsed_pids.discard(pid)

        sessions = cached_sessions
        procs = cached_procs

        row = 0

        # ── Single-row header ──
        n_sessions = len(sessions)
        n_procs = len(procs)
        total_agents = sum(len(s.get("subagents", [])) for s in sessions)
        total_cpu = sum(p["cpu"] for p in procs)
        total_mem = sum(p["mem_rss"] for p in procs)

        view_label = VIEW_NAMES[view_mode]
        title = f" clanager [{view_label}]"
        stats_right = (
            f"{n_sessions} sess  {total_agents} agents  {n_procs} proc  "
            f"CPU {total_cpu:.0f}%  MEM {format_bytes(total_mem).strip()}  "
            f"{now} "
        )

        safe_addstr(stdscr, row, 0, " " * w, SEL_HDR)
        safe_addstr(stdscr, row, 0, title, SEL_HDR)
        safe_addstr(stdscr, row, max(0, w - len(stats_right)), stats_right, SEL_HDR)
        row += 1

        # Jump flash feedback
        if jump_flash > 0:
            jump_flash -= 1
            flash_msg = " → jumped to tmux tab "
            safe_addstr(stdscr, row, max(0, (w - len(flash_msg)) // 2), flash_msg, GREEN)
            row += 1

        spin_frame += 1

        C = {
            "brand": BRAND, "beige": BEIGE, "amber": AMBER, "red": RED,
            "green": GREEN, "slate": SLATE, "sel": SEL_HDR, "dim": DIM,
            "peach": PEACH, "cream": CREAM,
            "teal": TEAL, "purple": PURPLE,
        }

        if view_mode == VIEW_SESSIONS:
            row = draw_sessions_view(stdscr, row, h, w, sessions,
                                     sort_idx_sessions, cursor_idx, selected_pid,
                                     collapsed_pids, spin_frame, C)
            # Rebuild display rows for cursor navigation
            cached_display_rows = build_display_rows(sessions, collapsed_pids)
            # Clamp cursor
            if cached_display_rows:
                max_idx = len(cached_display_rows) - 1
                cursor_idx = min(cursor_idx, max_idx)
                # Skip separator if cursor landed on one
                while cursor_idx > 0 and cached_display_rows[cursor_idx][0] == "separator":
                    cursor_idx -= 1
            else:
                cursor_idx = 0
        elif view_mode == VIEW_PROCESSES:
            cursor_idx = min(cursor_idx, max(0, len(procs) - 1))
            row = draw_processes_view(stdscr, row, h, w, procs,
                                      sort_idx_procs, cursor_idx, C)
        elif view_mode == VIEW_HISTORY:
            daily = stats_cache.get("dailyActivity", [])
            cursor_idx = min(cursor_idx, max(0, len(daily[-14:]) - 1))
            row = draw_history_view(stdscr, row, h, w, stats_cache,
                                    cursor_idx, C)

        # ── Footer ──
        footer = " q:Quit  Tab/v:View  s:Sort  g:Jump  Enter:Expand  p:Pause  ↑↓:Nav "
        safe_addstr(stdscr, h - 1, 0, " " * w, SEL_HDR)
        safe_addstr(stdscr, h - 1, 1, truncate(footer, w - 2), SEL_HDR)

        stdscr.refresh()


SPINNER_FRAMES = ["✶", "✸", "✹", "✺", "✹", "✸"]
ACTIVITY_IDLE = {"Idle", "Waiting"}

THINKING_WORDS = [
    "Thinking", "Computing", "Pondering", "Ruminating", "Cogitating",
    "Contemplating", "Deliberating", "Noodling", "Percolating", "Brewing",
    "Simmering", "Crystallizing", "Orchestrating", "Synthesizing", "Channeling",
