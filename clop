            cached_sessions = get_active_sessions()
            cached_procs = find_claude_processes()
            last_data_refresh = time.time()

            # Prune stale _subagent_cache entries for exited sessions
            active_subagent_keys = set()
            for s in cached_sessions:
                for a in s.get("subagents", []):
                    subdir = a.get("_subagent_dir")
                    if subdir:
                        active_subagent_keys.add((subdir, a["agent_id"]))
            with _subagent_cache_lock:
                for stale_key in set(_subagent_cache) - active_subagent_keys:
                    del _subagent_cache[stale_key]

            # Auto-expand sessions with active agents (unless user manually collapsed)
            for s in cached_sessions:
                pid = s["pid"]
                if pid not in manually_toggled:
                    n_active = sum(1 for a in s.get("subagents", [])
                                   if a.get("activity") not in ACTIVITY_IDLE)
                    if n_active > 0:
                        collapsed_pids.discard(pid)

