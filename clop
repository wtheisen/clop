def _status_word(activity, pid_or_id):
    """Resolve a fun status word for JSON API consumers."""
    is_active = activity not in ACTIVITY_IDLE
    if isinstance(pid_or_id, int):
        idx = pid_or_id % len(THINKING_WORDS)
    else:
        idx = hash(pid_or_id) % len(THINKING_WORDS)
    if is_active:
        return THINKING_WORDS[idx]
    return DONE_WORDS[idx % len(DONE_WORDS)]


def _serialize_session(s):
    """Serialize a session dict for JSON, stripping internal keys."""
    out = {}
    for k, v in s.items():
        if k.startswith("_"):
            continue
        out[k] = v
    # Add status word
    out["status_word"] = _status_word(s.get("activity", "Idle"), s.get("pid", 0))
    # Serialize subagents
    if "subagents" in out:
        out["subagents"] = [_serialize_subagent(a) for a in out["subagents"]]
    return out


def _serialize_subagent(a):
    """Serialize a subagent dict for JSON, stripping internal keys."""
    out = {}
    for k, v in a.items():
        if k.startswith("_"):
            continue
        out[k] = v
    out["status_word"] = _status_word(a.get("activity", "Idle"), a.get("agent_id", ""))
    return out


def get_active_orchestrators(sessions=None):
    """Find running orchestrator.sh processes in tmux and parse their config."""
    if sessions is None:
        sessions = get_active_sessions()
    orchestrators = []
    try:
        result = subprocess.run(
            ["tmux", "list-panes", "-a", "-F",
             "#{pane_pid}:#{pane_current_command}:#{pane_id}"],
            capture_output=True, text=True, timeout=3
        )
        if result.returncode != 0:
            return orchestrators
    except (subprocess.TimeoutExpired, FileNotFoundError):
        return orchestrators

    for line in result.stdout.strip().split("\n"):
        if not line:
            continue
        parts = line.split(":", 2)
        if len(parts) < 3:
            continue
        pane_pid_str, cmd, pane_id = parts
        try:
            pane_pid = int(pane_pid_str)
        except ValueError:
            continue

        # Walk descendants of the pane to find orchestrator.sh
        try:
            pane_proc = psutil.Process(pane_pid)
            descendants = [pane_proc] + pane_proc.children(recursive=True)
        except (psutil.NoSuchProcess, psutil.AccessDenied):
            continue

        for desc in descendants:
            try:
                cmdline = desc.cmdline()
                cmdline_str = " ".join(cmdline).lower()
                if "orchestrator" not in cmdline_str:
                    continue

                # Try to find config JSON path from cmdline args
                config_path = None
                for i, arg in enumerate(cmdline):
                    if arg.endswith(".json") and os.path.exists(arg):
                        config_path = arg
                        break

                orch_info = {
                    "type": "unknown",
                    "repo": "",
                    "item_count": 0,
                    "elapsed": time.time() - desc.create_time(),
                    "slugs": [],
                    "phase": "running",
                    "workers": [],
                }

                if config_path:
                    try:
                        with open(config_path) as cf:
                            config = json.load(cf)
                        orch_info["type"] = config.get("type", "unknown")
                        orch_info["repo"] = config.get("repo", "")
                        items = config.get("items", [])
                        orch_info["item_count"] = len(items)
                        slugs = [item.get("slug", "") for item in items if isinstance(item, dict)]
                        orch_info["slugs"] = slugs
                    except (OSError, json.JSONDecodeError):
                        pass

                # Try to parse runs.log for recent completed runs
                runs_log = os.path.expanduser(
                    "~/Dropbox/linux_files/claude/logs/runs.log"
                )
                if os.path.exists(runs_log):
                    try:
                        with open(runs_log, "rb") as rl:
                            rl.seek(max(0, os.path.getsize(runs_log) - 32768))
                            tail = rl.read().decode("utf-8", errors="replace")
                        for log_line in tail.strip().split("\n"):
                            try:
                                entry = json.loads(log_line)
                                if entry.get("type") == orch_info["type"]:
                                    orch_info["phase"] = entry.get("phase", "running")
                            except (json.JSONDecodeError, ValueError):
                                pass
                    except OSError:
                        pass

                # Cross-reference worker worktrees with active sessions
                for slug in orch_info["slugs"]:
                    worker_cwd_pattern = f"/tmp/{orch_info['type']}-{slug}"
                    worker = {"slug": slug, "status": "pending", "activity": "", "context_pct": 0}
                    for sess in sessions:
                        if sess.get("cwd", "").startswith(worker_cwd_pattern):
                            worker["status"] = "active" if sess["activity"] not in ACTIVITY_IDLE else "idle"
                            worker["activity"] = sess["activity"]
                            worker["context_pct"] = sess["context_pct"]
                            # Derive parent project from worker worktree
                            if not orch_info["repo"] and sess.get("parent_project"):
                                orch_info["repo"] = sess["parent_project"]
                            break
                    orch_info["workers"].append(worker)

                # Also try to derive repo from worktree if still empty
                if not orch_info["repo"] and orch_info["slugs"]:
                    for slug in orch_info["slugs"]:
                        wt_path = f"/tmp/{orch_info['type']}-{slug}"
                        parent = _resolve_worktree_parent(wt_path)
                        if not parent:
                            parent = _resolve_worktree_parent(f"/private{wt_path}")
                        if parent:
                            orch_info["repo"] = os.path.basename(parent)
                            break

                orchestrators.append(orch_info)
            except (psutil.NoSuchProcess, psutil.AccessDenied):
                continue

    return orchestrators


