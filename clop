def draw_sessions_view(stdscr, row, h, w, sessions, sort_idx, cursor_idx,
                       selected_pid, collapsed_pids, spin_frame, C):
    """Draw sessions with tree-view subagents."""
    sort_key = SORT_MODES_SESSIONS[sort_idx]

    key_fn = {
        "activity": lambda s: (
            1 if s["activity"] in ACTIVITY_IDLE else 0,
            s["context_pct"],
        ),
        "context": lambda s: s["context_pct"],
        "tokens": lambda s: s["output_tokens"],
        "msgs": lambda s: s["msg_count"],
        "time": lambda s: s["elapsed"],
    }[sort_key]
    sessions.sort(key=key_fn, reverse=True)

    if not sessions:
        msg = "No active Claude sessions"
        safe_addstr(stdscr, row, max(0, (w - len(msg)) // 2), msg, C["amber"])
        row += 2
        safe_addstr(stdscr, row, max(0, (w - 28) // 2), "Start one with: claude", C["dim"])
        return row + 1

    # Build flat display rows
    display_rows = build_display_rows(sessions, collapsed_pids)

    avail = h - row - 1 - 2  # header + separator line

    # Find scroll position to keep cursor visible
    scroll_top = 0
    if cursor_idx >= avail + scroll_top:
        scroll_top = cursor_idx - avail + 1
    scroll_top = max(0, min(scroll_top, len(display_rows) - avail))

    visible_rows = display_rows[scroll_top: scroll_top + avail]

    # ── Compute column widths from visible sessions ──
    visible_sessions = [r[1] for r in visible_rows if r[0] == "session"]
    if not visible_sessions:
        visible_sessions = sessions[:1]

    proj_w = max((len(s["project"] or "~") for s in visible_sessions), default=4)
    proj_w = max(proj_w, 7)

    fun_word_w = 14
    for s in visible_sessions:
        idx = s["pid"] % len(THINKING_WORDS)
        fun_word_w = max(fun_word_w, len(THINKING_WORDS[idx]) + 3)
        fun_word_w = max(fun_word_w, len(DONE_WORDS[idx % len(DONE_WORDS)]) + 3)

    def get_phase(s):
        activity = s.get("activity", "Idle")
        if activity in ACTIVITY_IDLE:
            return ""
        if "Responding" in activity:
            return "responding"
        if "Using " in activity or "Running " in activity:
            return (activity.split(" ", 1)[1] if " " in activity else "tool").lower()
        return "thinking"

    time_w = 8
    out_w = 7
    phase_w = 24
    bar_w = max(6, int(w * 0.12))
    ctx_label_w = 12
    perm_w = 11
    model_w = 12
    agents_w = 14  # "3/5 active"

    col_proj = 2
    col_status = col_proj + proj_w + 1
    col_time = col_status + fun_word_w + 1
    col_out = col_time + time_w + 1
    col_mode = col_out + out_w + 1
    col_bar = col_mode + perm_w + 1
    col_after_bar = col_bar + bar_w + ctx_label_w + 1
    col_agents = col_after_bar
    col_after_agents = col_agents + agents_w + 1
    col_phase = col_after_agents

    show_agents = col_agents + agents_w < w
    show_phase = col_phase + phase_w < w
    col_after_phase = (col_phase + phase_w + 1) if show_phase else col_after_agents
    show_model = col_after_phase + model_w < w

    # ── Column headers ──
    hdr = C["beige"] | curses.A_BOLD
    safe_addstr(stdscr, row, col_proj, "PROJECT", hdr)
    safe_addstr(stdscr, row, col_status, "STATUS", hdr)
    safe_addstr(stdscr, row, col_time, "TURN", hdr)
    safe_addstr(stdscr, row, col_out, "OUTPUT", hdr)
    safe_addstr(stdscr, row, col_mode, "MODE", hdr)
    safe_addstr(stdscr, row, col_bar, "CONTEXT", hdr)
    if show_agents:
        safe_addstr(stdscr, row, col_agents, "AGENTS", hdr)
    if show_phase:
        safe_addstr(stdscr, row, col_phase, "PHASE", hdr)
    if show_model:
        safe_addstr(stdscr, row, w - model_w - 1, "MODEL", hdr)
    row += 1
    safe_addstr(stdscr, row, 1, "─" * (w - 2), C["dim"])
    row += 1

    for di, drow in enumerate(visible_rows):
        if row >= h - 1:
            break

        abs_idx = scroll_top + di
        is_cursor = (abs_idx == cursor_idx)

        if drow[0] == "separator":
            if row < h - 1:
                safe_addstr(stdscr, row, 1, "─" * (w - 2), C["dim"])
                row += 1
            continue

        if drow[0] == "session":
            s = drow[1]
            pct = s["context_pct"]
            ctx_color = C["red"] if pct > 80 else (C["amber"] if pct > 50 else C["green"])
            activity = s.get("activity", "Idle")
            is_active = activity not in ACTIVITY_IDLE
            project = s["project"] or "~"
            model = shorten_model(s["model"])
            out_tok = format_tokens(s["output_tokens"])
            n_agents = s.get("_n_total_agents", 0)
            n_active_agents = s.get("_n_active_agents", 0)

            # Turn time
            turn_time = ""
            turn_time_color = C["slate"]
            if is_active and s.get("turn_start_ts"):
                try:
                    ts = datetime.fromisoformat(s["turn_start_ts"].replace("Z", "+00:00"))
                    elapsed_s = (datetime.now(timezone.utc) - ts).total_seconds()
                    if elapsed_s >= 0:
                        turn_time = format_time(elapsed_s)
                        turn_time_color = C["brand"]
                except (ValueError, TypeError):
                    pass
            elif not is_active and s.get("last_turn_duration") is not None:
                turn_time = format_time(s["last_turn_duration"])
            if not turn_time:
                turn_time = format_time(s["elapsed"])

            # Cursor
            if is_cursor:
                safe_addstr(stdscr, row, 0, "▸", C["brand"])

            # Collapse/expand indicator
            if n_agents > 0:
                is_collapsed = s["pid"] in collapsed_pids
                indicator = "▶" if is_collapsed else "▼"
                safe_addstr(stdscr, row, 1, indicator, C["dim"])

            # Project
            safe_addstr(stdscr, row, col_proj, truncate(project, proj_w), C["peach"] | curses.A_BOLD)

            # Status
            if is_active:
                spinner = SPINNER_FRAMES[spin_frame % len(SPINNER_FRAMES)]
                word_idx = s["pid"] % len(THINKING_WORDS)
                fun_word = THINKING_WORDS[word_idx]
                safe_addstr(stdscr, row, col_status, f"{spinner} {fun_word}…", C["brand"])
            else:
                word_idx = s["pid"] % len(DONE_WORDS)
                safe_addstr(stdscr, row, col_status, f"✻ {DONE_WORDS[word_idx]}", C["slate"])

            # Turn time
            safe_addstr(stdscr, row, col_time, turn_time, turn_time_color)

            # Output tokens
            safe_addstr(stdscr, row, col_out, out_tok, C["slate"])

            # Mode
            perm = s.get("permission_mode", "?")
            perm_info = {
                "bypassPermissions": ("⏵⏵ Bypass", C["red"]),
                "dontAsk":           ("⏵⏵ DontAsk", C["red"]),
                "auto":              ("⏵⏵ Auto", C["amber"]),
                "acceptEdits":       ("⏵⏵ Accept", C["purple"]),
                "plan":              ("⏸ Plan", C["teal"]),
                "default":           ("Default", C["dim"]),
            }.get(perm)
            if perm_info:
                perm_label, perm_color = perm_info
                safe_addstr(stdscr, row, col_mode, truncate(perm_label, perm_w), perm_color)

            # Context bar
            if pct < 25:
                bar_fg = C["green"]
            elif pct < 50:
                bar_fg = C["brand"]
            elif pct < 80:
                bar_fg = C["amber"]
            else:
                bar_fg = C["red"]
            draw_bar(stdscr, row, col_bar, bar_w, pct, bar_fg, C["dim"])
            ctx_label = f" {format_tokens(s['total_context'])}/{format_tokens(s['context_max'])}"
            safe_addstr(stdscr, row, col_bar + bar_w, ctx_label, ctx_color)

            # Agents column
            if show_agents:
                if n_agents > 0:
                    if n_active_agents > 0:
                        agent_str = f"{n_active_agents}/{n_agents} active"
                        safe_addstr(stdscr, row, col_agents, agent_str, C["brand"])
                    else:
                        agent_str = f"{n_agents} done"
                        safe_addstr(stdscr, row, col_agents, agent_str, C["slate"])

            # Phase
            if show_phase:
                phase = get_phase(s)
                if phase:
                    phase_color = C["brand"] if phase == "thinking" else C["amber"]
                    safe_addstr(stdscr, row, col_phase, truncate(phase, phase_w), phase_color)

            # Model (right-aligned)
            if show_model:
                safe_addstr(stdscr, row, w - model_w - 1, model, C["beige"])
            row += 1

            # Expanded detail line (for selected_pid)
            if s["pid"] == selected_pid and row < h - 1:
                stats_parts = [
                    f"Msgs {s['msg_count']}",
                    f"Tools {s['tool_calls']}",
                    f"Out {format_tokens(s['output_tokens'])}",
                    f"PID {s['pid']}",
                    f"MEM {format_bytes(s['mem']).strip()}",
                ]
                stats_line = "  │  ".join(stats_parts)
                safe_addstr(stdscr, row, col_status, truncate(stats_line, w - col_status - 1), C["slate"])
                row += 1

        elif drow[0] == "agent":
            agent = drow[1]
            parent = drow[2]
            is_last = drow[3]

            agent_activity = agent.get("activity", "Idle")
            agent_active = agent_activity not in ACTIVITY_IDLE
            agent_type = agent.get("type", "?")
            agent_desc = agent.get("desc", "")
            agent_pct = agent.get("context_pct", 0)
            agent_out = format_tokens(agent.get("output_tokens", 0))

            # Tree line
            tree_char = "└─" if is_last else "├─"

            # Cursor
            if is_cursor:
                safe_addstr(stdscr, row, 0, "▸", C["brand"])

            # Tree connector + agent type
            indent = 4
            safe_addstr(stdscr, row, indent, tree_char, C["dim"])
            type_label = truncate(agent_type, 12)
            safe_addstr(stdscr, row, indent + 3, type_label, C["teal"] | curses.A_BOLD)

            # Agent status (compact)
            agent_status_col = indent + 3 + 13
            if agent_active:
                spinner = SPINNER_FRAMES[spin_frame % len(SPINNER_FRAMES)]
                # Use agent_id hash for word index
                word_idx = hash(agent.get("agent_id", "")) % len(THINKING_WORDS)
                fun_word = THINKING_WORDS[word_idx]
                safe_addstr(stdscr, row, agent_status_col, f"{spinner} {fun_word}…", C["brand"])
            else:
                word_idx = hash(agent.get("agent_id", "")) % len(DONE_WORDS)
                safe_addstr(stdscr, row, agent_status_col, f"✻ {DONE_WORDS[word_idx]}", C["slate"])

            # Agent turn time
            agent_time_col = agent_status_col + fun_word_w + 1
            agent_turn = ""
            agent_time_color = C["slate"]
            if agent_active and agent.get("turn_start_ts"):
                try:
                    ts = datetime.fromisoformat(agent["turn_start_ts"].replace("Z", "+00:00"))
                    elapsed_s = (datetime.now(timezone.utc) - ts).total_seconds()
                    if elapsed_s >= 0:
                        agent_turn = format_time(elapsed_s)
                        agent_time_color = C["brand"]
                except (ValueError, TypeError):
                    pass
            elif not agent_active and agent.get("last_turn_duration") is not None:
                agent_turn = format_time(agent["last_turn_duration"])
            if agent_turn:
                safe_addstr(stdscr, row, agent_time_col, agent_turn, agent_time_color)

            # Agent output tokens
            agent_out_col = agent_time_col + time_w + 1
            safe_addstr(stdscr, row, agent_out_col, agent_out, C["slate"])

            # Agent context mini-bar
            agent_bar_col = agent_out_col + out_w + 1
            mini_bar_w = max(4, bar_w // 2)
            if agent_bar_col + mini_bar_w + ctx_label_w < w:
                if agent_pct < 25:
                    abf = C["green"]
                elif agent_pct < 50:
                    abf = C["brand"]
                elif agent_pct < 80:
                    abf = C["amber"]
                else:
                    abf = C["red"]
                draw_bar(stdscr, row, agent_bar_col, mini_bar_w, agent_pct, abf, C["dim"])
                actx = f" {format_tokens(agent.get('total_context', 0))}/{format_tokens(agent.get('context_max', DEFAULT_CONTEXT))}"
                actx_color = C["red"] if agent_pct > 80 else (C["amber"] if agent_pct > 50 else C["green"])
                safe_addstr(stdscr, row, agent_bar_col + mini_bar_w, actx, actx_color)

            # Agent description (fill remaining space)
            desc_col = agent_bar_col + mini_bar_w + ctx_label_w + 2
            if agent_desc and desc_col < w - 2:
                desc_w = w - desc_col - 1
                safe_addstr(stdscr, row, desc_col, truncate(agent_desc, desc_w), C["dim"])

            row += 1

    return row


def draw_processes_view(stdscr, row, h, w, procs, sort_idx, cursor_idx, C):
    """Draw the OS process view."""
    sort_key = SORT_MODES_PROCS[sort_idx]
    reverse = sort_key in ("cpu", "mem", "time")
    key_fn = {
        "cpu": lambda p: p["cpu"],
        "mem": lambda p: p["mem_rss"],
        "pid": lambda p: p["pid"],
        "time": lambda p: p["elapsed"],
    }[sort_key]
    procs.sort(key=key_fn, reverse=reverse)

    hdr = (
        f"{'PID':>7} {'PPID':>7} {'USER':<10} {'TYPE':<6} "
        f"{'THR':>4} {'CPU%':>6} {'MEM%':>6} {'RSS':>8} "
        f"{'TIME':>8}  {'COMMAND'}"
    )
    hdr = truncate(hdr, w)
    safe_addstr(stdscr, row, 0, hdr, C["beige"] | curses.A_BOLD)
    col_name = SORT_LABELS_PROCS[sort_key]
    idx = hdr.find(col_name)
    if idx >= 0:
        safe_addstr(stdscr, row, idx, col_name, C["sel"])
    row += 1

    avail = h - row - 1
    scroll_top = 0
    if cursor_idx >= avail:
        scroll_top = cursor_idx - avail + 1
    visible = procs[scroll_top: scroll_top + avail]

    for i, p in enumerate(visible):
        if row >= h - 1:
            break
        abs_idx = scroll_top + i
        is_cursor = (abs_idx == cursor_idx)
        ptype = classify_process(p["cmdline"])
        cpu_color = C["red"] if p["cpu"] > 50 else (C["amber"] if p["cpu"] > 10 else C["slate"])

        if is_cursor:
            safe_addstr(stdscr, row, 0, "▸", C["brand"])

        line = (
            f"{p['pid']:>7} "
            f"{p['ppid']:>7} "
            f"{truncate(p['user'], 10):<10} "
            f"{ptype:<6} "
            f"{p['threads']:>4} "
            f"{p['cpu']:>6.1f} "
            f"{p['mem_pct']:>6.1f} "
            f"{format_bytes(p['mem_rss']).strip():>8} "
            f"{format_time(p['elapsed']):>8}  "
            f"{p['cmdline']}"
        )
        safe_addstr(stdscr, row, 1, truncate(line, w - 1), C["slate"])
        cpu_pos = 1 + 7 + 1 + 7 + 1 + 10 + 1 + 6 + 1 + 4 + 1
        safe_addstr(stdscr, row, cpu_pos, f"{p['cpu']:>6.1f}", cpu_color)
        row += 1

    if not procs:
        safe_addstr(stdscr, row, max(0, (w - 24) // 2), "No Claude processes found", C["amber"])
        row += 1

    return row


def draw_history_view(stdscr, row, h, w, stats, cursor_idx, C):
    """Draw historical usage stats from stats-cache.json."""

    model_usage = stats.get("modelUsage", {})
    daily = stats.get("dailyActivity", [])
    total_sessions = stats.get("totalSessions", 0)
    total_messages = stats.get("totalMessages", 0)
    first_date = stats.get("firstSessionDate", "")

    safe_addstr(stdscr, row, 1, "LIFETIME STATS", C["brand"] | curses.A_BOLD)
    row += 1

    safe_addstr(stdscr, row, 3, f"Sessions: {total_sessions}", C["slate"])
    safe_addstr(stdscr, row, 25, f"Messages: {total_messages:,}", C["slate"])
    if first_date:
        safe_addstr(stdscr, row, 50, f"Since: {first_date[:10]}", C["dim"])
    row += 1

    row += 1
    safe_addstr(stdscr, row, 1, "MODEL USAGE (lifetime)", C["brand"] | curses.A_BOLD)
    row += 1

    model_hdr = f"  {'MODEL':<28} {'INPUT':>10} {'OUTPUT':>10} {'CACHE READ':>12} {'CACHE WRITE':>12}"
    safe_addstr(stdscr, row, 0, truncate(model_hdr, w), C["beige"])
    row += 1

    for model_name, usage in model_usage.items():
        inp = usage.get("inputTokens", 0)
        out = usage.get("outputTokens", 0)
        cr = usage.get("cacheReadInputTokens", 0)
        cw = usage.get("cacheCreationInputTokens", 0)

        line = (
            f"  {shorten_model(model_name):<28} "
            f"{format_tokens(inp):>10} "
            f"{format_tokens(out):>10} "
            f"{format_tokens(cr):>12} "
            f"{format_tokens(cw):>12}"
        )
        safe_addstr(stdscr, row, 0, truncate(line, w), C["slate"])
        safe_addstr(stdscr, row, 2, shorten_model(model_name), C["peach"])
        row += 1

    row += 1
    safe_addstr(stdscr, row, 1, "RECENT DAILY ACTIVITY", C["brand"] | curses.A_BOLD)
    row += 1

    recent = daily[-14:]
    if recent:
        day_hdr = f"   {'DATE':<12} {'MSGS':>7} {'SESSIONS':>9} {'TOOLS':>7}  {'ACTIVITY'}"
        safe_addstr(stdscr, row, 0, truncate(day_hdr, w), C["beige"])
        row += 1

        max_msgs = max((d.get("messageCount", 0) for d in recent), default=1) or 1
        bar_area = max(10, w - 43)

        avail = h - row - 1
        scroll_top = 0
        if cursor_idx >= avail:
            scroll_top = cursor_idx - avail + 1
        scroll_top = min(scroll_top, max(0, len(recent) - avail))
        visible = recent[scroll_top: scroll_top + avail]

        for i, d in enumerate(visible):
            if row >= h - 1:
                break
            abs_idx = scroll_top + i
            is_cursor = (abs_idx == cursor_idx)
            date = d.get("date", "?")
            msgs = d.get("messageCount", 0)
            sess = d.get("sessionCount", 0)
            tools = d.get("toolCallCount", 0)
            bar_len = int(bar_area * msgs / max_msgs) if max_msgs else 0

            if is_cursor:
                safe_addstr(stdscr, row, 0, " ▸", C["brand"])

            safe_addstr(stdscr, row, 3, f"{date:<12}", C["slate"])
            safe_addstr(stdscr, row, 15, f"{msgs:>7}", C["amber"] if msgs > 2000 else C["slate"])
            safe_addstr(stdscr, row, 22, f"{sess:>9}", C["slate"])
            safe_addstr(stdscr, row, 31, f"{tools:>7}", C["slate"])
            safe_addstr(stdscr, row, 40, "█" * bar_len, C["brand"])
            row += 1
    else:
        safe_addstr(stdscr, row, 3, "No daily activity data available", C["dim"])
        row += 1

    return row


