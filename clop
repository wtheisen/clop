#!/usr/bin/env python3
"""claude-top: A top-like TUI for monitoring Claude Code sessions and processes."""

import curses
import json
import glob
import time
import psutil
import os
import re
from datetime import datetime, timedelta
from pathlib import Path

REFRESH_INTERVAL = 0.08  # seconds (fast spinner animation)
CLAUDE_DIR = Path.home() / ".claude"
CLAUDE_KEYWORDS = ["claude", "anthropic"]

# Context window sizes by model
MODEL_CONTEXT = {
    "claude-opus-4-6": 1_000_000,
    "claude-opus-4-5-20251101": 200_000,
    "claude-sonnet-4-6": 200_000,
    "claude-sonnet-4-5-20251022": 200_000,
    "claude-haiku-4-5-20251001": 200_000,
}
DEFAULT_CONTEXT = 200_000

# View modes
VIEW_SESSIONS = 0
VIEW_PROCESSES = 1
VIEW_HISTORY = 2
VIEW_NAMES = ["Sessions", "Processes", "History"]

SORT_MODES_SESSIONS = ["context", "tokens", "msgs", "time"]
SORT_LABELS_SESSIONS = {"context": "CTX%", "tokens": "TOKENS", "msgs": "MSGS", "time": "TIME"}
SORT_MODES_PROCS = ["cpu", "mem", "pid", "time"]
SORT_LABELS_PROCS = {"cpu": "CPU%", "mem": "MEM%", "pid": "PID", "time": "TIME"}


def format_tokens(n):
    """Format token count to human-readable."""
    if n >= 1_000_000:
        return f"{n / 1_000_000:.1f}M"
    if n >= 1_000:
        return f"{n / 1_000:.1f}K"
    return str(n)


def format_bytes(b):
    for unit in ["B", "K", "M", "G", "T"]:
        if abs(b) < 1024.0:
            return f"{b:5.1f}{unit}"
        b /= 1024.0
    return f"{b:.1f}P"


def format_time(secs):
    h = int(secs // 3600)
    m = int((secs % 3600) // 60)
    s = int(secs % 60)
    if h > 0:
        return f"{h:d}:{m:02d}:{s:02d}"
    return f"{m:d}:{s:02d}"


def truncate(s, width):
    if len(s) <= width:
        return s
    return s[: width - 1] + "…"


def draw_bar(stdscr, y, x, width, pct, color_filled, color_empty=None):
    """Draw a percentage bar with optional two-tone coloring."""
    filled = int(width * min(pct, 100) / 100)
    filled = max(0, min(filled, width))
    try:
        if filled > 0:
            stdscr.addstr(y, x, "█" * filled, color_filled)
        remaining = width - filled
        if remaining > 0:
            empty_color = color_empty if color_empty else curses.color_pair(5)
            stdscr.addstr(y, x + filled, "░" * remaining, empty_color)
    except curses.error:
        pass


def safe_addstr(stdscr, y, x, text, attr=0):
    try:
        stdscr.addstr(y, x, text, attr)
    except curses.error:
        pass


def get_active_sessions():
    """Get all active Claude Code sessions with their metadata."""
    sessions = []
    session_files = glob.glob(str(CLAUDE_DIR / "sessions" / "*.json"))

    for sf in session_files:
        try:
            pid = int(Path(sf).stem)
            # Check if process is alive
            if not psutil.pid_exists(pid):
                continue

            with open(sf) as f:
                data = json.load(f)

            session_id = data.get("sessionId", "")
            cwd = data.get("cwd", "")
            started_at = data.get("startedAt", 0)
            elapsed = (time.time() * 1000 - started_at) / 1000 if started_at else 0

            # Get process info
            try:
                proc = psutil.Process(pid)
                cpu = proc.cpu_percent(interval=0)
                mem = proc.memory_info().rss
                # Count child processes
                children = proc.children(recursive=True)
                n_children = len(children)
                total_mem = mem + sum(c.memory_info().rss for c in children if c.is_running())
            except (psutil.NoSuchProcess, psutil.AccessDenied):
                cpu = 0
                mem = 0
                n_children = 0
                total_mem = 0

            # Find the conversation JSONL for this session
            ctx_info = get_session_context(session_id, cwd)

            # CPU-based fallback: if JSONL says "Waiting"/"Idle" but process
            # is using significant CPU, the JSONL hasn't been flushed yet
            # (streaming in progress). Override to "Active".
            if ctx_info["activity"] in ("Waiting", "Idle") and cpu > 5.0:
                ctx_info["activity"] = "Active"

            sessions.append({
                "pid": pid,
                "session_id": session_id,
                "cwd": cwd,
                "project": os.path.basename(cwd) if cwd else "?",
                "elapsed": elapsed,
                "cpu": cpu,
                "mem": total_mem,
                "children": n_children,
                **ctx_info,
            })
        except (json.JSONDecodeError, ValueError, OSError):
            continue

    return sessions


def get_session_context(session_id, cwd):
    """Extract context window usage from a session's JSONL file."""
    result = {
        "model": "?",
        "input_tokens": 0,
        "output_tokens": 0,
        "cache_read": 0,
        "cache_write": 0,
        "total_context": 0,
        "context_max": DEFAULT_CONTEXT,
        "context_pct": 0,
        "permission_mode": "?",
        "subagents": [],
        "msg_count": 0,
        "tool_calls": 0,
        "activity": "Idle",
        "slug": "",
    }

    if not session_id:
        return result

    # Find the JSONL file. The session JSON's sessionId can go stale after
    # context compaction — Claude Code creates new JSONLs with new IDs.
    # Strategy: compute the project dir from CWD, then find the most
    # recently modified JSONL there. Fall back to exact session_id match.
    jsonl_path = None
    project_dir = None

    if cwd:
        # Project dir name = CWD with / and _ replaced by -
        project_dir_name = cwd.replace("/", "-").replace("_", "-")
        candidate_dir = str(CLAUDE_DIR / "projects" / project_dir_name)
        if os.path.isdir(candidate_dir):
            project_dir = candidate_dir
            # Find most recently modified JSONL in this project dir (top-level only)
            best_mtime = 0
            for f in os.listdir(candidate_dir):
                if f.endswith(".jsonl"):
                    fpath = os.path.join(candidate_dir, f)
                    try:
                        mt = os.path.getmtime(fpath)
                        if mt > best_mtime:
                            best_mtime = mt
                            jsonl_path = fpath
                    except OSError:
                        pass

    if not jsonl_path:
        # Fall back: search all project dirs by exact session_id
        for pd in glob.glob(str(CLAUDE_DIR / "projects" / "*")):
            candidate = os.path.join(pd, f"{session_id}.jsonl")
            if os.path.exists(candidate):
                jsonl_path = candidate
                project_dir = pd
                break

    if not jsonl_path:
        return result

    # Read the JSONL efficiently — scan from the end for recent usage data
    try:
        # Read last chunk of file for recent messages
        file_size = os.path.getsize(jsonl_path)
        read_size = min(file_size, 512 * 1024)  # last 512KB

        msg_count = 0
        tool_calls = 0
        last_model = None
        last_usage = None
        last_slug = ""
        total_input = 0
        total_output = 0
        total_cache_read = 0
        total_cache_write = 0
        last_type = ""
        last_role = ""
        last_content_types = []
        last_tool_name = ""
        # Track assistant state separately: the last assistant entry
        # with a real stop_reason tells us if the turn finished
        last_assistant_stop = None  # None = no assistant msg seen, or still streaming
        last_assistant_ctypes = []
        last_assistant_tool = ""
        # Sequence tracking for chronological ordering
        entry_seq = 0
        last_assistant_seq = 0
        last_user_seq = 0
        last_user_ctypes = []
        last_progress_type = ""  # "agent_progress" if subagent is active
        permission_mode = "?"

        with open(jsonl_path, "rb") as f:
            # Single-pass: read from tail; estimate skipped messages from file size
            f.seek(max(0, file_size - read_size))
            if file_size > read_size:
                f.readline()  # skip partial line

            for line in f:
                try:
                    entry = json.loads(line)
                except (json.JSONDecodeError, UnicodeDecodeError):
                    continue

                if entry.get("permissionMode"):
                    permission_mode = entry["permissionMode"]

                if entry.get("slug"):
                    last_slug = entry["slug"]

                msg = entry.get("message", {})
                if not isinstance(msg, dict):
                    continue

                usage = msg.get("usage", {})
                model = msg.get("model", "")

                if model:
                    last_model = model

                if usage:
                    last_usage = usage
                    inp = usage.get("input_tokens", 0)
                    out = usage.get("output_tokens", 0)
                    cr = usage.get("cache_read_input_tokens", 0)
                    cw = usage.get("cache_creation_input_tokens", 0)
                    total_input += inp
                    total_output += out
                    total_cache_read += cr
                    total_cache_write += cw

                content = msg.get("content", [])
                if isinstance(content, list):
                    for item in content:
                        if isinstance(item, dict) and item.get("type") == "tool_use":
                            tool_calls += 1

                # Track last message state for activity detection
                entry_type = entry.get("type", "")

                # Track progress entries for subagent detection
                if entry_type == "progress":
                    progress_data_type = entry.get("data", {}).get("type", "")
                    if progress_data_type == "agent_progress":
                        last_progress_type = "agent_progress"
                    # Non-agent progress doesn't clear agent state
                elif entry_type in ("assistant", "user"):
                    # A real assistant/user entry after agent_progress means agent finished
                    last_progress_type = ""

                msg_count += 1

                if entry_type in ("assistant", "user"):
                    entry_seq += 1
                    last_type = entry_type
                    last_role = msg.get("role", "")
                    last_content_types = []
                    last_tool_name = ""
                    if isinstance(content, list):
                        for item in content:
                            if isinstance(item, dict):
                                last_content_types.append(item.get("type", ""))
                                if item.get("type") == "tool_use":
                                    last_tool_name = item.get("name", "")
                                elif item.get("type") == "tool_result":
                                    last_tool_name = ""

                    # Track assistant entries specifically
                    if entry_type == "assistant":
                        stop = msg.get("stop_reason")  # None while streaming, str when done
                        last_assistant_ctypes = list(last_content_types)
                        last_assistant_tool = last_tool_name
                        last_assistant_stop = stop
                        last_assistant_seq = entry_seq

                    # Track user entries specifically
                    if entry_type == "user":
                        last_user_ctypes = list(last_content_types)
                        last_user_seq = entry_seq

        # Estimate messages in the skipped portion of the file
        if file_size > read_size and msg_count > 0:
            tail_start = max(0, file_size - read_size)
            bytes_read = file_size - tail_start
            if bytes_read > 0:
                avg_line_size = bytes_read / msg_count
                skipped_estimate = int(tail_start / avg_line_size)
                msg_count += skipped_estimate

        # Estimate current context from the most recent usage
        if last_usage:
            # The last message's cache_read + cache_creation + input + output
            # approximates total context consumed
            ctx_tokens = (
                last_usage.get("cache_read_input_tokens", 0)
                + last_usage.get("cache_creation_input_tokens", 0)
                + last_usage.get("input_tokens", 0)
                + last_usage.get("output_tokens", 0)
            )
        else:
            ctx_tokens = 0

        ctx_max = MODEL_CONTEXT.get(last_model, DEFAULT_CONTEXT) if last_model else DEFAULT_CONTEXT
        ctx_pct = (ctx_tokens / ctx_max * 100) if ctx_max else 0

        # Derive activity status from last message state
        # "Waiting" strictly means the session needs user keyboard input.
        # Everything else gets an active status describing what's happening.
        activity = "Idle"

        if last_progress_type == "agent_progress":
            # Subagent is actively running
            activity = "Running Agent"
        elif last_type == "assistant":
            if last_assistant_stop is not None:
                if last_assistant_stop == "end_turn":
                    # Model finished its turn — genuinely waiting for user
                    activity = "Waiting"
                elif last_assistant_stop == "tool_use":
                    tool_label = last_assistant_tool or "tool"
                    if last_user_seq > last_assistant_seq and "tool_result" in last_user_ctypes:
                        # Tool completed, result sent back — assistant processing
                        activity = "Thinking"
                    else:
                        # Tool executing or awaiting approval
                        activity = f"Running {tool_label}"
                else:
                    # max_tokens, stop_sequence, etc — turn ended
                    activity = "Waiting"
            else:
                # stop_reason is None → still streaming
                if "thinking" in last_assistant_ctypes:
                    activity = "Thinking"
                elif any(ct.startswith("tool_use") for ct in last_assistant_ctypes):
                    tool_label = last_assistant_tool or "tool"
                    activity = f"Using {tool_label}"
                elif "text" in last_assistant_ctypes:
                    activity = "Responding"
                else:
                    activity = "Thinking"
        elif last_type == "user":
            activity = "Thinking"

        # Find subagents for this session
        subagents = []
        jsonl_dir = os.path.dirname(jsonl_path)
        jsonl_session_id = os.path.basename(jsonl_path).replace(".jsonl", "")
        subagent_dir = os.path.join(jsonl_dir, jsonl_session_id, "subagents")
        if os.path.isdir(subagent_dir):
            for meta_file in glob.glob(os.path.join(subagent_dir, "*.meta.json")):
                try:
                    with open(meta_file) as mf:
                        meta = json.load(mf)
                    subagents.append({
                        "type": meta.get("agentType", "?"),
                        "desc": meta.get("description", ""),
                    })
                except (OSError, json.JSONDecodeError):
                    pass

        result.update({
            "activity": activity,
            "permission_mode": permission_mode,
            "subagents": subagents,
            "model": last_model or "?",
            "input_tokens": total_input,
            "output_tokens": total_output,
            "cache_read": total_cache_read,
            "cache_write": total_cache_write,
            "total_context": ctx_tokens,
            "context_max": ctx_max,
            "context_pct": min(ctx_pct, 100),
            "msg_count": msg_count,
            "tool_calls": tool_calls,
            "slug": last_slug,
        })
    except OSError:
        pass

    return result


def get_stats_cache():
    """Read the stats cache for historical usage data."""
    path = CLAUDE_DIR / "stats-cache.json"
    try:
        with open(path) as f:
            return json.load(f)
    except (OSError, json.JSONDecodeError):
        return {}


def find_claude_processes():
    """Find all processes related to Claude."""
    procs = []
    for proc in psutil.process_iter(
        ["pid", "ppid", "name", "cmdline", "cpu_percent", "memory_info",
         "memory_percent", "create_time", "status", "username", "num_threads"]
    ):
        try:
            info = proc.info
            name = (info["name"] or "").lower()
            cmdline = " ".join(info["cmdline"] or []).lower()

            is_claude = any(kw in name or kw in cmdline for kw in CLAUDE_KEYWORDS)
            if not is_claude:
                continue

            mem_info = info["memory_info"]
            create_time = info["create_time"]
            elapsed = time.time() - create_time if create_time else 0

            procs.append({
                "pid": info["pid"],
                "ppid": info["ppid"],
                "name": info["name"] or "?",
                "cmdline": " ".join(info["cmdline"] or []),
                "cpu": info["cpu_percent"] or 0.0,
                "mem_pct": info["memory_percent"] or 0.0,
                "mem_rss": mem_info.rss if mem_info else 0,
                "elapsed": elapsed,
                "status": info["status"] or "?",
                "user": info["username"] or "?",
                "threads": info["num_threads"] or 0,
            })
        except (psutil.NoSuchProcess, psutil.AccessDenied, psutil.ZombieProcess):
            continue
    return procs


def classify_process(cmdline):
    cl = cmdline.lower()
    if "claude-code" in cl or "claude code" in cl:
        return "Code"
    if "mcp" in cl:
        return "MCP"
    if "node" in cl and "claude" in cl:
        return "Node"
    if "claude" in cl:
        return "Claude"
    return "Other"


def shorten_model(model):
    """Shorten model name for display."""
    if not model or model == "?":
        return "?"
    m = model.lower()
    if "opus-4-6" in m:
        return "opus-4.6"
    if "opus-4-5" in m:
        return "opus-4.5"
    if "sonnet-4-6" in m:
        return "sonnet-4.6"
    if "sonnet-4-5" in m:
        return "sonnet-4.5"
    if "haiku-4-5" in m:
        return "haiku-4.5"
    if "haiku" in m:
        return "haiku"
    # Fallback: last meaningful part
    parts = model.split("-")
    return "-".join(parts[:3]) if len(parts) > 3 else model


def main(stdscr):
    curses.curs_set(0)
    stdscr.nodelay(True)
    stdscr.timeout(int(REFRESH_INTERVAL * 1000))

    curses.start_color()
    curses.use_default_colors()

    # ── Anthropic brand palette (true color where supported) ──
    # #da7756 = terracotta (primary brand)    rgb(218, 119, 86)
    # #ccbea7 = warm beige (secondary)        rgb(204, 190, 167)
    # #f3d5a3 = light peach (accent)          rgb(243, 213, 163)
    # #e39437 = amber (warning/highlight)     rgb(227, 148, 55)
    # #1a1a1a = near-black (bg)               rgb(26, 26, 26)
    # #10b981 = emerald (success)             rgb(16, 185, 129)
    # #dc2626 = red (error/high)              rgb(220, 38, 38)
    # #94a3b8 = slate (muted text)            rgb(148, 163, 184)

    has_custom_colors = curses.can_change_color() and curses.COLORS >= 256

    if has_custom_colors:
        # Define custom colors (curses uses 0-1000 range for RGB)
        def hex_to_curses(r, g, b):
            return int(r / 255 * 1000), int(g / 255 * 1000), int(b / 255 * 1000)

        C_TERRACOTTA = 16
        C_BEIGE = 17
        C_PEACH = 18
        C_AMBER = 19
        C_DARK = 20
        C_EMERALD = 21
        C_CRIMSON = 22
        C_SLATE = 23
        C_CREAM = 24
        C_PARCHMENT = 25

        curses.init_color(C_TERRACOTTA, *hex_to_curses(218, 119, 86))
        curses.init_color(C_BEIGE, *hex_to_curses(204, 190, 167))
        curses.init_color(C_PEACH, *hex_to_curses(243, 213, 163))
        curses.init_color(C_AMBER, *hex_to_curses(227, 148, 55))
        curses.init_color(C_DARK, *hex_to_curses(26, 26, 26))
        curses.init_color(C_EMERALD, *hex_to_curses(16, 185, 129))
        curses.init_color(C_CRIMSON, *hex_to_curses(220, 38, 38))
        curses.init_color(C_SLATE, *hex_to_curses(148, 163, 184))
        curses.init_color(C_CREAM, *hex_to_curses(251, 240, 223))
        curses.init_color(C_PARCHMENT, *hex_to_curses(246, 222, 206))

        curses.init_pair(1, C_EMERALD, -1)       # success/green
        curses.init_pair(2, C_BEIGE, -1)          # secondary text
        curses.init_pair(3, C_AMBER, -1)          # warning/highlight
        curses.init_pair(4, C_CRIMSON, -1)        # error/high
        curses.init_pair(5, C_SLATE, -1)          # normal/muted
        curses.init_pair(6, C_TERRACOTTA, -1)     # brand primary
        curses.init_pair(7, C_CREAM, C_TERRACOTTA)  # selected header
        curses.init_pair(8, C_DARK, C_EMERALD)    # bar green
        curses.init_pair(9, C_DARK, C_AMBER)      # bar yellow/amber
        curses.init_pair(10, C_DARK, C_CRIMSON)   # bar red
        curses.init_pair(11, C_DARK, C_TERRACOTTA)  # bar brand
        curses.init_pair(12, C_DARK, C_BEIGE)     # bar muted
        curses.init_pair(13, C_PEACH, -1)         # peach accent
        curses.init_pair(14, C_CREAM, -1)         # cream text
    else:
        # Fallback to standard 8-color terminal
        curses.init_pair(1, curses.COLOR_GREEN, -1)
        curses.init_pair(2, curses.COLOR_CYAN, -1)
        curses.init_pair(3, curses.COLOR_YELLOW, -1)
        curses.init_pair(4, curses.COLOR_RED, -1)
        curses.init_pair(5, curses.COLOR_WHITE, -1)
        curses.init_pair(6, curses.COLOR_YELLOW, -1)   # closest to terracotta
        curses.init_pair(7, curses.COLOR_WHITE, curses.COLOR_RED)
        curses.init_pair(8, curses.COLOR_BLACK, curses.COLOR_GREEN)
        curses.init_pair(9, curses.COLOR_BLACK, curses.COLOR_YELLOW)
        curses.init_pair(10, curses.COLOR_BLACK, curses.COLOR_RED)
        curses.init_pair(11, curses.COLOR_BLACK, curses.COLOR_YELLOW)
        curses.init_pair(12, curses.COLOR_BLACK, curses.COLOR_CYAN)
        curses.init_pair(13, curses.COLOR_YELLOW, -1)
        curses.init_pair(14, curses.COLOR_WHITE, -1)

    # Semantic color aliases
    GREEN = curses.color_pair(1) | curses.A_BOLD
    BEIGE = curses.color_pair(2)
    AMBER = curses.color_pair(3)
    RED = curses.color_pair(4) | curses.A_BOLD
    SLATE = curses.color_pair(5)
    BRAND = curses.color_pair(6) | curses.A_BOLD   # terracotta
    SEL_HDR = curses.color_pair(7) | curses.A_BOLD
    DIM = curses.color_pair(5) | curses.A_DIM
    BAR_GREEN = curses.color_pair(8)
    BAR_AMBER = curses.color_pair(9)
    BAR_RED = curses.color_pair(10)
    BAR_BRAND = curses.color_pair(11)
    BAR_MUTED = curses.color_pair(12)
    PEACH = curses.color_pair(13)
    CREAM = curses.color_pair(14)

    view_mode = VIEW_SESSIONS
    sort_idx_sessions = 0
    sort_idx_procs = 0
    cursor_idx = 0     # highlighted row in current view
    selected_idx = -1  # -1 = no session expanded
    paused = False

    # Prime CPU
    find_claude_processes()
    stats_cache = get_stats_cache()
    last_stats_refresh = time.time()
    last_data_refresh = 0  # force immediate data load
    cached_sessions = []
    cached_procs = []
    spin_frame = 0
    DATA_REFRESH_INTERVAL = 2.0  # read files every 2s, render every 0.5s

    while True:
        key = stdscr.getch()
        if key == ord("q") or key == ord("Q"):
            break
        elif key == ord("\t") or key == ord("v") or key == ord("V"):
            view_mode = (view_mode + 1) % 3
            cursor_idx = 0
            selected_idx = -1
        elif key == ord("1"):
            view_mode = VIEW_SESSIONS
            cursor_idx = 0
        elif key == ord("2"):
            view_mode = VIEW_PROCESSES
            cursor_idx = 0
        elif key == ord("3"):
            view_mode = VIEW_HISTORY
            cursor_idx = 0
        elif key == ord("s") or key == ord("S"):
            if view_mode == VIEW_SESSIONS:
                sort_idx_sessions = (sort_idx_sessions + 1) % len(SORT_MODES_SESSIONS)
            elif view_mode == VIEW_PROCESSES:
                sort_idx_procs = (sort_idx_procs + 1) % len(SORT_MODES_PROCS)
        elif key == ord("p") or key == ord("P"):
            paused = not paused
        elif key == curses.KEY_UP:
            cursor_idx = max(0, cursor_idx - 1)
        elif key == curses.KEY_DOWN:
            if view_mode == VIEW_SESSIONS:
                max_items = len(cached_sessions)
            elif view_mode == VIEW_PROCESSES:
                max_items = len(cached_procs)
            else:
                max_items = len(stats_cache.get("dailyActivity", []))
            cursor_idx = min(cursor_idx + 1, max(0, max_items - 1))
        elif key == curses.KEY_HOME:
            cursor_idx = 0
        elif key == ord("\n") or key == ord(" "):
            if view_mode == VIEW_SESSIONS:
                if selected_idx == cursor_idx:
                    selected_idx = -1
                else:
                    selected_idx = cursor_idx

        if paused:
            try:
                h, w = stdscr.getmaxyx()
                msg = " PAUSED (press p to resume) "
                stdscr.addstr(0, max(0, w - len(msg) - 1), msg, RED)
            except curses.error:
                pass
            stdscr.refresh()
            continue

        stdscr.erase()
        h, w = stdscr.getmaxyx()

        if h < 10 or w < 60:
            safe_addstr(stdscr, 0, 0, "Terminal too small (need 60x10+)", RED)
            stdscr.refresh()
            continue

        # Refresh stats cache every 30s
        if time.time() - last_stats_refresh > 30:
            stats_cache = get_stats_cache()
            last_stats_refresh = time.time()

        now = datetime.now().strftime("%H:%M:%S")

        # Throttle expensive data reads, but render every frame for spinner
        if time.time() - last_data_refresh >= DATA_REFRESH_INTERVAL:
            cached_sessions = get_active_sessions()
            cached_procs = find_claude_processes()
            last_data_refresh = time.time()
        sessions = cached_sessions
        procs = cached_procs

        row = 0

        # ── Single-row header ──
        n_sessions = len(sessions)
        n_procs = len(procs)
        total_cpu = sum(p["cpu"] for p in procs)
        total_mem = sum(p["mem_rss"] for p in procs)

        view_label = VIEW_NAMES[view_mode]
        title = f" clop [{view_label}]"
        stats_right = (
            f"{n_sessions} sess  {n_procs} proc  "
            f"CPU {total_cpu:.0f}%  MEM {format_bytes(total_mem).strip()}  "
            f"{now} "
        )

        safe_addstr(stdscr, row, 0, " " * w, SEL_HDR)
        safe_addstr(stdscr, row, 0, title, SEL_HDR)
        safe_addstr(stdscr, row, max(0, w - len(stats_right)), stats_right, SEL_HDR)
        row += 1

        spin_frame += 1

        # Pack colors into a dict so we don't pass 15 positional args
        C = {
            "brand": BRAND, "beige": BEIGE, "amber": AMBER, "red": RED,
            "green": GREEN, "slate": SLATE, "sel": SEL_HDR, "dim": DIM,
            "peach": PEACH, "cream": CREAM,
            "bar_green": BAR_GREEN, "bar_amber": BAR_AMBER,
            "bar_red": BAR_RED, "bar_brand": BAR_BRAND, "bar_muted": BAR_MUTED,
        }

        # ── View-specific content ──
        if view_mode == VIEW_SESSIONS:
            row = draw_sessions_view(stdscr, row, h, w, sessions,
                                     sort_idx_sessions, cursor_idx, selected_idx,
                                     spin_frame, C)
        elif view_mode == VIEW_PROCESSES:
            row = draw_processes_view(stdscr, row, h, w, procs,
                                      sort_idx_procs, cursor_idx, C)
        elif view_mode == VIEW_HISTORY:
            row = draw_history_view(stdscr, row, h, w, stats_cache,
                                    cursor_idx, C)

        # ── Footer ──
        footer = " q:Quit  Tab/v:View  s:Sort  p:Pause  1-3:View  ↑↓:Scroll  Enter:Details "
        safe_addstr(stdscr, h - 1, 0, " " * w, SEL_HDR)
        safe_addstr(stdscr, h - 1, 1, truncate(footer, w - 2), SEL_HDR)

        stdscr.refresh()


SPINNER_FRAMES = ["✶", "✸", "✹", "✺", "✹", "✸"]
ACTIVITY_IDLE = {"Idle", "Waiting"}

# Claude Code's fun status words (sampled from the real list)
THINKING_WORDS = [
    "Thinking", "Computing", "Pondering", "Ruminating", "Cogitating",
    "Contemplating", "Deliberating", "Noodling", "Percolating", "Brewing",
    "Simmering", "Crystallizing", "Orchestrating", "Synthesizing", "Channeling",
    "Manifesting", "Incubating", "Germinating", "Hatching", "Composing",
    "Crafting", "Forging", "Architecting", "Calibrating", "Harmonizing",
    "Gallivanting", "Combobulating", "Clauding", "Nebulizing", "Vibing",
]


def draw_sessions_view(stdscr, row, h, w, sessions, sort_idx, cursor_idx,
                       selected_idx, spin_frame, C):
    """Draw sessions as single rows; expand stats for selected session."""
    sort_key = SORT_MODES_SESSIONS[sort_idx]

    key_fn = {
        "context": lambda s: s["context_pct"],
        "tokens": lambda s: s["output_tokens"],
        "msgs": lambda s: s["msg_count"],
        "time": lambda s: s["elapsed"],
    }[sort_key]
    sessions.sort(key=key_fn, reverse=True)

    if not sessions:
        msg = "No active Claude sessions"
        safe_addstr(stdscr, row, max(0, (w - len(msg)) // 2), msg, C["amber"])
        row += 2
        safe_addstr(stdscr, row, max(0, (w - 28) // 2), "Start one with: claude", C["dim"])
        return row + 1

    avail = h - row - 1 - 2  # subtract 2 for column header + separator
    # Each session takes 2 rows (content + separator), selected takes more
    max_visible = max(1, avail // 2)
    # Auto-scroll so cursor is always visible
    scroll_top = 0
    if cursor_idx >= max_visible:
        scroll_top = cursor_idx - max_visible + 1
    visible = sessions[scroll_top: scroll_top + max_visible]

    # ── Compute fixed column widths from all visible data ──
    proj_w = max((len(s["project"] or "~") for s in visible), default=4)
    proj_w = max(proj_w, 4)  # minimum

    # Status column: widest status text across sessions
    def status_len(s):
        activity = s.get("activity", "Idle")
        uptime = format_time(s["elapsed"])
        out_tok = format_tokens(s["output_tokens"])
        if activity not in ACTIVITY_IDLE:
            word_idx = s["pid"] % len(THINKING_WORDS)
            fun_word = THINKING_WORDS[word_idx]
            phase = "thinking"
            if "Responding" in activity:
                phase = "responding"
            elif "Using " in activity or "Running " in activity:
                phase = (activity.split(" ", 1)[1] if " " in activity else "tool").lower()
            # "✶ Word… (time · ↓ tok tokens · phase)"
            return 2 + len(fun_word) + 2 + len(f"({uptime} · ↓ {out_tok} tokens · {phase})")
        else:
            return 2 + len(f"Waiting ({uptime} · ↓ {out_tok} tokens)")

    status_w = max((status_len(s) for s in visible), default=20)

    bar_w = max(6, int(w * 0.12))
    ctx_label_w = 12  # " 100.5K/1.0M"
    model_w = 12  # "sonnet-4.5  "
    slug_w = max((len(s.get("slug", "")) for s in visible), default=0)
    right_w = slug_w + 2 + model_w if slug_w else model_w

    # Fixed column positions (col 0 reserved for cursor indicator)
    col_proj = 2
    col_status = col_proj + proj_w + 1
    col_bar = col_status + status_w + 1
    col_right = w - right_w - 1

    # ── Column headers ──
    safe_addstr(stdscr, row, col_proj, "PROJECT", C["beige"] | curses.A_BOLD)
    safe_addstr(stdscr, row, col_status, "STATUS", C["beige"] | curses.A_BOLD)
    if col_bar + bar_w + ctx_label_w < col_right:
        safe_addstr(stdscr, row, col_bar, "CONTEXT", C["beige"] | curses.A_BOLD)
    if slug_w:
        safe_addstr(stdscr, row, col_right, "SLUG", C["beige"] | curses.A_BOLD)
    safe_addstr(stdscr, row, w - model_w - 1, "MODEL", C["beige"] | curses.A_BOLD)
    row += 1
    safe_addstr(stdscr, row, 1, "─" * (w - 2), C["dim"])
    row += 1

    for i, s in enumerate(visible):
        if row >= h - 1:
            break

        session_abs_idx = scroll_top + i
        is_cursor = (session_abs_idx == cursor_idx)
        is_selected = (session_abs_idx == selected_idx)

        pct = s["context_pct"]
        ctx_color = C["red"] if pct > 80 else (C["amber"] if pct > 50 else C["green"])
        slug = s.get("slug", "")
        activity = s.get("activity", "Idle")
        is_active = activity not in ACTIVITY_IDLE

        project = s["project"] or "~"
        model = shorten_model(s["model"])
        uptime = format_time(s["elapsed"])
        out_tok = format_tokens(s["output_tokens"])

        # ── Cursor indicator ──
        if is_cursor:
            safe_addstr(stdscr, row, 0, "▸", C["brand"])

        # ── Col 1: Project name ──
        safe_addstr(stdscr, row, col_proj, truncate(project, proj_w), C["peach"] | curses.A_BOLD)

        # ── Col 2: Status ──
        col = col_status
        if is_active:
            spinner = SPINNER_FRAMES[spin_frame % len(SPINNER_FRAMES)]
            word_idx = s["pid"] % len(THINKING_WORDS)
            fun_word = THINKING_WORDS[word_idx]

            phase = "thinking"
            if "Responding" in activity:
                phase = "responding"
            elif "Using " in activity or "Running " in activity:
                tool = activity.split(" ", 1)[1] if " " in activity else "tool"
                phase = tool.lower()

            safe_addstr(stdscr, row, col, spinner, C["brand"])
            col += 2
            status_word = f"{fun_word}…"
            safe_addstr(stdscr, row, col, status_word, C["brand"])
            col += len(status_word) + 1

            detail = f"({uptime} · ↓ {out_tok} tokens · {phase})"
            safe_addstr(stdscr, row, col, detail, C["slate"])
        else:
            safe_addstr(stdscr, row, col, "●", C["green"])
            col += 2
            wait_text = f"Waiting ({uptime} · ↓ {out_tok} tokens)"
            safe_addstr(stdscr, row, col, wait_text, C["green"])

        # ── Col 3: Context bar ──
        if col_bar + bar_w + ctx_label_w < col_right:
            if pct < 25:
                bar_fg = C["green"]
            elif pct < 50:
                bar_fg = C["brand"]
            elif pct < 80:
                bar_fg = C["amber"]
            else:
                bar_fg = C["red"]
            draw_bar(stdscr, row, col_bar, bar_w, pct, bar_fg, C["dim"])
            ctx_label = f" {format_tokens(s['total_context'])}/{format_tokens(s['context_max'])}"
            safe_addstr(stdscr, row, col_bar + bar_w, ctx_label, ctx_color)

        # ── Col 4: Right-aligned slug + model ──
        if slug:
            safe_addstr(stdscr, row, col_right, truncate(slug, slug_w), C["dim"])
            safe_addstr(stdscr, row, col_right + slug_w + 2, model, C["beige"])
        else:
            safe_addstr(stdscr, row, w - model_w - 1, model, C["beige"])
        row += 1

        # ── Expanded details (only for selected session) ──
        if is_selected and row < h - 1:
            perm = s.get("permission_mode", "?")
            perm_label = {
                "bypassPermissions": "bypass",
                "acceptEdits": "accept-edits",
                "default": "default",
                "dontAsk": "dont-ask",
                "plan": "plan",
                "auto": "auto",
            }.get(perm, perm)

            stats_parts = [
                f"Msgs {s['msg_count']}",
                f"Tools {s['tool_calls']}",
                f"Out {format_tokens(s['output_tokens'])}",
                f"PID {s['pid']}",
                f"MEM {format_bytes(s['mem']).strip()}",
            ]
            stats_line = "  │  ".join(stats_parts)
            safe_addstr(stdscr, row, col_status, truncate(stats_line, w - col_status - 1), C["slate"])
            perm_str = f" [{perm_label}]"
            perm_pos = col_status + len(stats_line) + 1
            if perm_pos + len(perm_str) < w:
                perm_color = C["amber"] if perm_label == "bypass" else C["dim"]
                safe_addstr(stdscr, row, perm_pos, perm_str, perm_color)
            row += 1

            subagents = s.get("subagents", [])
            if subagents and row < h - 1:
                agent_strs = [f"{a['type']}: {a['desc']}" for a in subagents[:3]]
                agent_line = "agents: " + "  │  ".join(agent_strs)
                safe_addstr(stdscr, row, col_status, truncate(agent_line, w - col_status - 1), C["beige"])
                row += 1

        # ── Separator ──
        if row < h - 1:
            safe_addstr(stdscr, row, 1, "─" * (w - 2), C["dim"])
            row += 1

    return row


def draw_processes_view(stdscr, row, h, w, procs, sort_idx, cursor_idx, C):
    """Draw the OS process view."""
    sort_key = SORT_MODES_PROCS[sort_idx]
    reverse = sort_key in ("cpu", "mem", "time")
    key_fn = {
        "cpu": lambda p: p["cpu"],
        "mem": lambda p: p["mem_rss"],
        "pid": lambda p: p["pid"],
        "time": lambda p: p["elapsed"],
    }[sort_key]
    procs.sort(key=key_fn, reverse=reverse)

    hdr = (
        f"{'PID':>7} {'PPID':>7} {'USER':<10} {'TYPE':<6} "
        f"{'THR':>4} {'CPU%':>6} {'MEM%':>6} {'RSS':>8} "
        f"{'TIME':>8}  {'COMMAND'}"
    )
    hdr = truncate(hdr, w)
    safe_addstr(stdscr, row, 0, hdr, C["beige"] | curses.A_BOLD)
    col_name = SORT_LABELS_PROCS[sort_key]
    idx = hdr.find(col_name)
    if idx >= 0:
        safe_addstr(stdscr, row, idx, col_name, C["sel"])
    row += 1

    avail = h - row - 1
    visible = procs[cursor_idx: cursor_idx + avail]

    for p in visible:
        if row >= h - 1:
            break
        ptype = classify_process(p["cmdline"])
        cpu_color = C["red"] if p["cpu"] > 50 else (C["amber"] if p["cpu"] > 10 else C["slate"])

        line = (
            f"{p['pid']:>7} "
            f"{p['ppid']:>7} "
            f"{truncate(p['user'], 10):<10} "
            f"{ptype:<6} "
            f"{p['threads']:>4} "
            f"{p['cpu']:>6.1f} "
            f"{p['mem_pct']:>6.1f} "
            f"{format_bytes(p['mem_rss']).strip():>8} "
            f"{format_time(p['elapsed']):>8}  "
            f"{p['cmdline']}"
        )
        safe_addstr(stdscr, row, 0, truncate(line, w), C["slate"])
        cpu_pos = 7 + 1 + 7 + 1 + 10 + 1 + 6 + 1 + 4 + 1
        safe_addstr(stdscr, row, cpu_pos, f"{p['cpu']:>6.1f}", cpu_color)
        row += 1

    if not procs:
        safe_addstr(stdscr, row, max(0, (w - 24) // 2), "No Claude processes found", C["amber"])
        row += 1

    return row


def draw_history_view(stdscr, row, h, w, stats, cursor_idx, C):
    """Draw historical usage stats from stats-cache.json."""

    model_usage = stats.get("modelUsage", {})
    daily = stats.get("dailyActivity", [])
    total_sessions = stats.get("totalSessions", 0)
    total_messages = stats.get("totalMessages", 0)
    first_date = stats.get("firstSessionDate", "")

    # ── Lifetime stats ──
    safe_addstr(stdscr, row, 1, "LIFETIME STATS", C["brand"] | curses.A_BOLD)
    row += 1

    safe_addstr(stdscr, row, 3, f"Sessions: {total_sessions}", C["slate"])
    safe_addstr(stdscr, row, 25, f"Messages: {total_messages:,}", C["slate"])
    if first_date:
        safe_addstr(stdscr, row, 50, f"Since: {first_date[:10]}", C["dim"])
    row += 1

    # ── Model usage breakdown ──
    row += 1
    safe_addstr(stdscr, row, 1, "MODEL USAGE (lifetime)", C["brand"] | curses.A_BOLD)
    row += 1

    model_hdr = f"  {'MODEL':<28} {'INPUT':>10} {'OUTPUT':>10} {'CACHE READ':>12} {'CACHE WRITE':>12}"
    safe_addstr(stdscr, row, 0, truncate(model_hdr, w), C["beige"])
    row += 1

    for model_name, usage in model_usage.items():
        inp = usage.get("inputTokens", 0)
        out = usage.get("outputTokens", 0)
        cr = usage.get("cacheReadInputTokens", 0)
        cw = usage.get("cacheCreationInputTokens", 0)

        line = (
            f"  {shorten_model(model_name):<28} "
            f"{format_tokens(inp):>10} "
            f"{format_tokens(out):>10} "
            f"{format_tokens(cr):>12} "
            f"{format_tokens(cw):>12}"
        )
        safe_addstr(stdscr, row, 0, truncate(line, w), C["slate"])
        safe_addstr(stdscr, row, 2, shorten_model(model_name), C["peach"])
        row += 1

    # ── Recent daily activity ──
    row += 1
    safe_addstr(stdscr, row, 1, "RECENT DAILY ACTIVITY", C["brand"] | curses.A_BOLD)
    row += 1

    recent = daily[-14:]
    if recent:
        day_hdr = f"  {'DATE':<12} {'MSGS':>7} {'SESSIONS':>9} {'TOOLS':>7}  {'ACTIVITY'}"
        safe_addstr(stdscr, row, 0, truncate(day_hdr, w), C["beige"])
        row += 1

        max_msgs = max((d.get("messageCount", 0) for d in recent), default=1) or 1
        bar_area = max(10, w - 42)

        start = max(0, len(recent) - (h - row - 1))
        for d in recent[start:]:
            if row >= h - 1:
                break
            date = d.get("date", "?")
            msgs = d.get("messageCount", 0)
            sess = d.get("sessionCount", 0)
            tools = d.get("toolCallCount", 0)
            bar_len = int(bar_area * msgs / max_msgs) if max_msgs else 0

            safe_addstr(stdscr, row, 2, f"{date:<12}", C["slate"])
            safe_addstr(stdscr, row, 14, f"{msgs:>7}", C["amber"] if msgs > 2000 else C["slate"])
            safe_addstr(stdscr, row, 21, f"{sess:>9}", C["slate"])
            safe_addstr(stdscr, row, 30, f"{tools:>7}", C["slate"])
            safe_addstr(stdscr, row, 39, "█" * bar_len, C["brand"])
            row += 1
    else:
        safe_addstr(stdscr, row, 3, "No daily activity data available", C["dim"])
        row += 1

    return row


