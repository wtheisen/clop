        result = subprocess.run(
            ["claude", "-p", prompt, "--output-format", "json"],
            capture_output=True, text=True, cwd=cwd,
            timeout=300,  # 5 minute timeout
        )
        with _skill_runs_lock:
            run = _skill_runs[run_id]
            if result.returncode == 0:
                try:
                    output = json.loads(result.stdout)
                    text = output.get("result", "")
                except (json.JSONDecodeError, KeyError):
                    text = result.stdout

                run["result"] = text
                if skill in SUGGESTION_SKILLS:
                    run["suggestions"] = _parse_suggestions(text)
                run["status"] = "done"
            else:
                run["error"] = result.stderr[:500] or "claude exited with error"
                run["status"] = "error"
    except subprocess.TimeoutExpired:
        with _skill_runs_lock:
            _skill_runs[run_id]["status"] = "error"
            _skill_runs[run_id]["error"] = "Timed out after 5 minutes"
    except Exception as e:
        with _skill_runs_lock:
            _skill_runs[run_id]["status"] = "error"
            _skill_runs[run_id]["error"] = str(e)


def run_skill(skill, cwd=None):
    """Start a skill run in the background. Returns (ok, run_id_or_message)."""
    if skill not in ALLOWED_SKILLS:
        return False, f"Unknown skill: {skill}. Allowed: {', '.join(sorted(ALLOWED_SKILLS))}"

    if not cwd:
        with _server_cache["lock"]:
            sessions = _server_cache["sessions"]
        if sessions:
            active = [s for s in sessions if s.get("activity") not in ACTIVITY_IDLE]
            cwd = (active[0] if active else sessions[0]).get("cwd", os.path.expanduser("~"))
        else:
            cwd = os.path.expanduser("~")

    if not os.path.isdir(cwd):
        cwd = os.path.expanduser("~")

    run_id = str(uuid.uuid4())[:8]
    project = os.path.basename(cwd)

    with _skill_runs_lock:
        _skill_runs[run_id] = {
            "run_id": run_id,
            "skill": skill,
            "cwd": cwd,
            "project": project,
            "status": "running",
            "result": None,
            "suggestions": [],
            "error": None,
            "started": time.time(),
        }

    t = threading.Thread(target=_run_skill_background, args=(run_id, skill, cwd), daemon=True)
    t.start()

    return True, run_id


def run_suggestions(run_id, indices):
    """Implement selected suggestions from a skill run.

    Uses the skill's `fix N,N,N` command to launch the orchestrator.
    """
    with _skill_runs_lock:
        run = _skill_runs.get(run_id)
        if not run:
            return False, "Run not found"
        if run["status"] != "done":
            return False, "Run not complete"

        valid = {s["index"] for s in run["suggestions"]}
        for idx in indices:
            if idx not in valid:
                return False, f"Suggestion {idx} not found"

        cwd = run["cwd"]
        skill = run["skill"]

    # Build implementation prompts from the selected suggestions
    selected = [s for s in run.get("suggestions", []) if s["index"] in indices]
    titles = [s["title"] for s in selected]

    # Build a prompt that implements the selected suggestions
    parts = [f"Implement these {skill} suggestions for this codebase:\n"]
    for s in selected:
        parts.append(f"{s['index']}. **{s['title']}**")
        if s.get("body"):
            parts.append(f"   {s['body']}\n")
        else:
            parts.append("")
    prompt = "\n".join(parts)

    # For multiple suggestions, spawn each in its own tmux window
    try:
        result = subprocess.run(
            ["tmux", "list-sessions", "-F", "#{session_name}"],
            capture_output=True, text=True, timeout=3
        )
        if result.returncode != 0:
            return False, "tmux is not running"
        tmux_sessions = result.stdout.strip().split("\n")
        target_session = "main" if "main" in tmux_sessions else tmux_sessions[0]
    except (subprocess.TimeoutExpired, FileNotFoundError):
        return False, "tmux not available"

    if len(selected) == 1:
        # Single suggestion: one window
        s = selected[0]
        single_prompt = f"Implement this fix:\n\n**{s['title']}**\n{s.get('body', '')}"
        window_name = f"{skill}-{s['index']}"
        escaped = single_prompt.replace("'", "'\\''")
        claude_cmd = f"cd '{cwd}' && claude -p '{escaped}' --dangerously-skip-permissions"
        subprocess.run(
            ["tmux", "new-window", "-t", target_session, "-n", window_name, claude_cmd],
            capture_output=True, text=True, timeout=5
        )
    else:
        # Multiple: one window per suggestion (parallel workers)
        for s in selected:
            single_prompt = f"Implement this fix:\n\n**{s['title']}**\n{s.get('body', '')}"
            window_name = f"{skill}-{s['index']}"
            escaped = single_prompt.replace("'", "'\\''")
            claude_cmd = f"cd '{cwd}' && claude -p '{escaped}' --dangerously-skip-permissions"
            subprocess.run(
                ["tmux", "new-window", "-t", target_session, "-n", window_name, claude_cmd],
                capture_output=True, text=True, timeout=5
            )

    fix_label = ",".join(str(s["index"]) for s in selected)
    return True, f"Implementing fix {fix_label}: {', '.join(titles)}"


class ClopAPIHandler(BaseHTTPRequestHandler):
    def do_GET(self):
        path = self.path.split("?")[0].rstrip("/")
        with _server_cache["lock"]:
            if path == "/api/sessions":
                data = [_serialize_session(s) for s in _server_cache["sessions"]]
            elif path == "/api/processes":
                data = _server_cache["processes"]
            elif path == "/api/history":
                data = _server_cache["history"]
            elif path == "/api/orchestrators":
                data = _server_cache["orchestrators"]
            elif path == "/api/skills":
                data = {
                    "available": sorted(ALLOWED_SKILLS),
                    "projects": list({s["cwd"]: s["project"]
                                      for s in _server_cache["sessions"]}.items()),
                }
            elif path == "/api/skill-runs":
                with _skill_runs_lock:
                    data = list(_skill_runs.values())
            elif path.startswith("/api/skill-runs/"):
                run_id = path.split("/")[-1]
                with _skill_runs_lock:
                    run = _skill_runs.get(run_id)
                if run:
                    data = run
                else:
                    self.send_error(404, "Run not found")
                    return
            else:
                self.send_error(404, "Not found")
                return

        body = json.dumps(data, default=str).encode("utf-8")
        self.send_response(200)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.send_header("Access-Control-Allow-Origin", "*")
        self.end_headers()
        self.wfile.write(body)

    def do_POST(self):
        path = self.path.split("?")[0].rstrip("/")
        if path not in ("/api/run-skill", "/api/run-suggestions"):
            self.send_error(404, "Not found")
            return

        content_length = int(self.headers.get("Content-Length", 0))
        if content_length > 4096:
            self.send_error(413, "Payload too large")
            return
        raw = self.rfile.read(content_length)
        try:
            payload = json.loads(raw)
        except (json.JSONDecodeError, UnicodeDecodeError):
            self.send_error(400, "Invalid JSON")
            return

        if path == "/api/run-skill":
            skill = payload.get("skill", "").strip()
            cwd = payload.get("cwd", "").strip() or None
            ok, result = run_skill(skill, cwd)
            if ok:
                data = {"ok": True, "run_id": result}
            else:
                data = {"ok": False, "message": result}
        else:  # /api/run-suggestions
            run_id = payload.get("run_id", "").strip()
            indices = payload.get("indices", [])
            try:
                indices = [int(i) for i in indices]
            except (ValueError, TypeError):
                indices = []
            ok, message = run_suggestions(run_id, indices)
            data = {"ok": ok, "message": message}

        body = json.dumps(data, default=str).encode("utf-8")
        self.send_response(200 if data["ok"] else 400)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.send_header("Access-Control-Allow-Origin", "*")
        self.end_headers()
        self.wfile.write(body)

    def do_OPTIONS(self):
        self.send_response(200)
        self.send_header("Access-Control-Allow-Origin", "*")
        self.send_header("Access-Control-Allow-Methods", "GET, POST, OPTIONS")
        self.send_header("Access-Control-Allow-Headers", "Content-Type")
        self.send_header("Content-Length", "0")
        self.end_headers()

    def log_message(self, format, *args):
        # Suppress default request logging noise
        pass


def serve_mode(port):
    """Run clop as an HTTP JSON API server."""
    # Prime caches
    find_claude_processes()

    # Start background refresh thread
    t = threading.Thread(target=_refresh_server_cache, daemon=True)
    t.start()

    # Wait for first data
    time.sleep(0.5)

    server = HTTPServer(("127.0.0.1", port), ClopAPIHandler)
    print(f"clop API server listening on http://127.0.0.1:{port}")
    print(f"  GET  /api/sessions      — active sessions with subagents")
    print(f"  GET  /api/processes     — Claude-related processes")
    print(f"  GET  /api/history       — historical stats")
    print(f"  GET  /api/orchestrators — running orchestrators")
    print(f"  GET  /api/skills        — available skills and projects")
    print(f"  POST /api/run-skill     — launch a skill in tmux")
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\nShutting down.")
        server.shutdown()


